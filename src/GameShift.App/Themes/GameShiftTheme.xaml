<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ============================================================
         GameShift Design Token System
         All GS.* resources are referenced via DynamicResource in views.
         ============================================================ -->

    <!-- Surface Colors -->
    <SolidColorBrush x:Key="GS.Surface.Base"     Color="#0D1117" />
    <SolidColorBrush x:Key="GS.Surface.Card"     Color="#1A1D23" />
    <SolidColorBrush x:Key="GS.Surface.Elevated" Color="#232323" />
    <SolidColorBrush x:Key="GS.Surface.Border"   Color="#2D333B" />

    <!-- Text Colors -->
    <SolidColorBrush x:Key="GS.Text.Primary"   Color="#DEDEDE" />
    <SolidColorBrush x:Key="GS.Text.Secondary"  Color="#999999" />
    <SolidColorBrush x:Key="GS.Text.Disabled"   Color="#626262" />

    <!-- Status Colors -->
    <SolidColorBrush x:Key="GS.Status.Active"   Color="#4ADE80" />
    <SolidColorBrush x:Key="GS.Status.Warning"  Color="#FBBF24" />
    <SolidColorBrush x:Key="GS.Status.Error"    Color="#F87171" />
    <SolidColorBrush x:Key="GS.Status.Info"     Color="#60A5FA" />
    <SolidColorBrush x:Key="GS.Status.Disabled" Color="#9CA3AF" />

    <!-- Badge Backgrounds (with alpha channel) -->
    <SolidColorBrush x:Key="GS.Badge.Active.Bg"  Color="#1A4ADE80" />
    <SolidColorBrush x:Key="GS.Badge.Warning.Bg" Color="#1AFBBF24" />
    <SolidColorBrush x:Key="GS.Badge.Error.Bg"   Color="#1AF87171" />

    <!-- Accent Colors -->
    <SolidColorBrush x:Key="GS.Accent.Primary" Color="#4ADE80" />
    <SolidColorBrush x:Key="GS.Accent.Hover"   Color="#6AEE9A" />

    <!-- ============================================================
         Typography Styles
         Apply with: Style="{DynamicResource GS.Text.Hero}"
         ============================================================ -->
    <Style x:Key="GS.Text.Hero" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI" />
        <Setter Property="FontSize"    Value="32" />
        <Setter Property="FontWeight"  Value="Bold" />
        <Setter Property="Foreground"  Value="{DynamicResource GS.Text.Primary}" />
    </Style>

    <Style x:Key="GS.Text.SectionHeader" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI" />
        <Setter Property="FontSize"    Value="15" />
        <Setter Property="FontWeight"  Value="SemiBold" />
        <Setter Property="Foreground"  Value="{DynamicResource GS.Text.Primary}" />
    </Style>

    <Style x:Key="GS.Text.Body" TargetType="TextBlock">
        <Setter Property="FontFamily"  Value="Segoe UI" />
        <Setter Property="FontSize"    Value="13" />
        <Setter Property="FontWeight"  Value="Normal" />
        <Setter Property="Foreground"  Value="{DynamicResource GS.Text.Primary}" />
    </Style>

    <!-- ============================================================
         Hero Button Style
         Large CTA button for one-click optimize. Green when idle,
         outline when optimized (revert action).
         ============================================================ -->
    <Style x:Key="GS.Button.Hero" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource GS.Accent.Primary}"/>
        <Setter Property="Foreground" Value="#0D1117"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="10" Padding="24,0">
                        <ContentPresenter HorizontalAlignment="Center"
                                          VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter Property="Background" Value="{DynamicResource GS.Accent.Hover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Background" Value="{DynamicResource GS.Surface.Elevated}"/>
                            <Setter Property="Foreground" Value="{DynamicResource GS.Text.Disabled}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
