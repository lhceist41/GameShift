<Page x:Class="GameShift.App.Views.Pages.LogViewerPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <DockPanel Margin="20">
        <!-- Header -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
            <TextBlock Text="Log Viewer" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Primary}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <Button Content="Refresh" Padding="10,4" Margin="0,0,8,0"
                        Background="{DynamicResource GS.Surface.Card}"
                        Foreground="{DynamicResource GS.Text.Primary}"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                        Cursor="Hand" FontSize="12"
                        Click="OnRefreshClicked"/>
                <Button Content="Open Folder" Padding="10,4"
                        Background="{DynamicResource GS.Surface.Card}"
                        Foreground="{DynamicResource GS.Text.Primary}"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                        Cursor="Hand" FontSize="12"
                        Click="OnOpenFolderClicked"/>
            </StackPanel>
        </DockPanel>

        <!-- Search Bar -->
        <Border DockPanel.Dock="Top" Margin="0,0,0,12"
                Background="{DynamicResource GS.Surface.Card}"
                CornerRadius="6" Padding="10,6"
                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
            <DockPanel>
                <TextBlock Text="Search:" DockPanel.Dock="Left"
                           VerticalAlignment="Center" Margin="0,0,8,0"
                           Foreground="{DynamicResource GS.Text.Secondary}" FontSize="12"/>
                <TextBox x:Name="SearchBox"
                         Text="{Binding SearchFilter, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                         Background="Transparent" Foreground="{DynamicResource GS.Text.Primary}"
                         BorderThickness="0" FontSize="13" VerticalAlignment="Center"/>
            </DockPanel>
        </Border>

        <!-- Status Bar -->
        <Border DockPanel.Dock="Bottom" Margin="0,8,0,0"
                Padding="8,4">
            <TextBlock Text="{Binding StatusText, Mode=OneWay}"
                       FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"/>
        </Border>

        <!-- Log Content -->
        <Border Background="{DynamicResource GS.Surface.Card}"
                CornerRadius="8" Padding="0"
                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
            <TextBox Text="{Binding LogContent, Mode=OneWay}"
                     IsReadOnly="True"
                     TextWrapping="NoWrap"
                     AcceptsReturn="True"
                     VerticalScrollBarVisibility="Auto"
                     HorizontalScrollBarVisibility="Auto"
                     FontFamily="Cascadia Mono, Consolas, Courier New"
                     FontSize="11"
                     Background="Transparent"
                     Foreground="{DynamicResource GS.Text.Primary}"
                     BorderThickness="0"
                     Padding="12,8"/>
        </Border>
    </DockPanel>
</Page>
