<Page x:Class="GameShift.App.Views.Pages.SetupWizardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  helpers:ScrollHelper.FixScrolling="True">
        <StackPanel Margin="24">

            <TextBlock Text="Setup Wizard" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,4"/>
            <TextBlock Text="Re-run the initial setup to scan hardware and configure GameShift."
                       FontSize="13" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,24"/>

            <!-- Hardware Scan Section -->
            <Border Background="{DynamicResource GS.Surface.Card}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Hardware Scan" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Detect your GPU, RAM, VBS status, and DPC latency baseline."
                               FontSize="13" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,16"/>

                    <Button x:Name="ScanButton" Content="Scan Hardware" Padding="16,8"
                            Background="{DynamicResource GS.Accent.Primary}"
                            Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"
                            Click="OnScanClicked"/>

                    <!-- Progress -->
                    <TextBlock x:Name="ScanProgress" Text="" FontSize="12"
                               Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,12,0,0"/>

                    <!-- Results -->
                    <Border x:Name="ResultsPanel" Visibility="Collapsed"
                            Background="{DynamicResource GS.Surface.Base}"
                            CornerRadius="6" Padding="16" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Scan Results" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,12"/>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="GPU:" FontWeight="SemiBold"
                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="GpuResult"
                                           Foreground="{DynamicResource GS.Text.Primary}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="RAM:" FontWeight="SemiBold"
                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="RamResult"
                                           Foreground="{DynamicResource GS.Text.Primary}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="VBS/HVCI:" FontWeight="SemiBold"
                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="VbsResult"
                                           Foreground="{DynamicResource GS.Text.Primary}"/>
                            </Grid>

                            <Grid Margin="0,0,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="120"/>
                                    <ColumnDefinition Width="*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DPC Baseline:" FontWeight="SemiBold"
                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                <TextBlock Grid.Column="1" x:Name="DpcResult"
                                           Foreground="{DynamicResource GS.Text.Primary}"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>

            <!-- Game Library Scan Section -->
            <Border Background="{DynamicResource GS.Surface.Card}"
                    CornerRadius="8" Padding="20" Margin="0,0,0,16"
                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                <StackPanel>
                    <TextBlock Text="Game Library Scan" FontSize="16" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,8"/>
                    <TextBlock Text="Scan Steam, Epic Games, and GOG libraries for installed games."
                               FontSize="13" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,16"/>

                    <Button x:Name="LibraryScanButton" Content="Scan Libraries" Padding="16,8"
                            Background="{DynamicResource GS.Accent.Primary}"
                            Foreground="White" BorderThickness="0"
                            FontWeight="SemiBold" Cursor="Hand"
                            Click="OnLibraryScanClicked"/>

                    <TextBlock x:Name="LibraryScanProgress" Text="" FontSize="12"
                               Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,12,0,0"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</Page>
