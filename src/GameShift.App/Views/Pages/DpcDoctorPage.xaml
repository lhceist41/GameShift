<Page x:Class="GameShift.App.Views.Pages.DpcDoctorPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      xmlns:vm="clr-namespace:GameShift.App.ViewModels"
      FontFamily="Segoe UI" FontSize="14">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <helpers:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
        <helpers:ImpactToFriendlyConverter x:Key="ImpactToFriendly"/>

        <!-- Slide-in animation for banners (200ms, CubicEase) -->
        <Style x:Key="AnimatedBannerStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-30"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    From="-30" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Page.Resources>

    <Grid>
        <!-- Admin Required Banner (shown when not admin) -->
        <Border Visibility="{Binding NotAdmin, Converter={StaticResource BoolToVisibility}}"
                Background="#1E293B" CornerRadius="8" Padding="20" Margin="20"
                VerticalAlignment="Top">
            <StackPanel HorizontalAlignment="Center">
                <TextBlock Text="&#xE7BA;" FontFamily="Segoe MDL2 Assets" FontSize="48"
                           Foreground="#F59E0B" HorizontalAlignment="Center" Margin="0,0,0,12"/>
                <TextBlock Text="DPC Doctor requires administrator privileges"
                           FontSize="18" FontWeight="SemiBold" Foreground="White"
                           HorizontalAlignment="Center" Margin="0,0,0,8"/>
                <TextBlock Text="Real-time driver analysis needs kernel-level access. Restart GameShift as administrator to unlock full DPC Doctor features."
                           Foreground="#94A3B8" TextWrapping="Wrap" TextAlignment="Center"
                           MaxWidth="500" Margin="0,0,0,16"/>
                <Button Content="Restart as Admin" Padding="20,8"
                        Background="#3B82F6" Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"
                        HorizontalAlignment="Center"
                        Click="OnRestartAsAdminClicked"/>
            </StackPanel>
        </Border>

        <!-- Main Content (shown when admin) -->
        <DockPanel Margin="20"
                   Visibility="{Binding IsAdmin, Converter={StaticResource BoolToVisibility}}">

            <!-- Header -->
            <DockPanel DockPanel.Dock="Top" Margin="0,0,0,16">
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left" VerticalAlignment="Center">
                    <TextBlock Text="DPC Doctor" FontSize="22" FontWeight="Bold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                    <Button Padding="4" Margin="8,0,0,0" Cursor="Hand"
                            Background="Transparent" BorderThickness="0"
                            VerticalAlignment="Center"
                            ToolTip="What is DPC?"
                            Click="OnDpcInfoToggleClicked">
                        <TextBlock Text="&#xE897;" FontFamily="Segoe MDL2 Assets" FontSize="16"
                                   Foreground="{DynamicResource GS.Text.Secondary}"/>
                    </Button>
                </StackPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBlock Text="Technical" Foreground="{DynamicResource GS.Text.Secondary}"
                               VerticalAlignment="Center" Margin="0,0,6,0" FontSize="12"/>
                    <CheckBox IsChecked="{Binding IsSimpleMode, Mode=TwoWay}"
                              VerticalAlignment="Center"/>
                    <TextBlock Text="Simple" Foreground="{DynamicResource GS.Text.Primary}"
                               VerticalAlignment="Center" Margin="6,0,0,0" FontSize="12"/>
                </StackPanel>
            </DockPanel>

            <!-- "What is DPC?" Info Panel (collapsible) -->
            <Border DockPanel.Dock="Top" Background="#1E293B" CornerRadius="8"
                    Padding="16" Margin="0,0,0,12"
                    Style="{StaticResource AnimatedBannerStyle}"
                    Visibility="{Binding ShowDpcInfoPanel, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <TextBlock Text="What is DPC?" FontSize="15" FontWeight="Bold"
                               Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,8"/>
                    <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource GS.Text.Secondary}" FontSize="13" LineHeight="20">
                        DPC stands for Deferred Procedure Call. In simple terms: every piece of hardware in your PC (GPU, network card, audio, USB devices) needs the CPU's attention regularly. If one device hogs the CPU for too long, everything else has to wait &#x2014; including your game. That wait is what causes stuttering, audio crackling, and input lag. DPC Doctor finds which device is hogging the CPU and fixes it.
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Scrollable content -->
            <ScrollViewer VerticalScrollBarVisibility="Auto"
                          helpers:ScrollHelper.FixScrolling="True">
                <StackPanel>

                    <!-- Fix Success Banner (green) -->
                    <Border Background="#052E16" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            BorderBrush="#4ADE80" BorderThickness="1"
                            Style="{StaticResource AnimatedBannerStyle}"
                            Visibility="{Binding ShowFixSuccessBanner, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <Button DockPanel.Dock="Right" Padding="6,2" Margin="10,0,0,0"
                                    Background="Transparent" BorderThickness="0" Cursor="Hand"
                                    VerticalAlignment="Top"
                                    Click="OnDismissSuccessBanner">
                                <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="12"
                                           Foreground="#94A3B8"/>
                            </Button>
                            <StackPanel>
                                <TextBlock Text="{Binding FixSuccessMessage}" FontWeight="Bold"
                                           Foreground="#4ADE80" FontSize="13"/>
                                <TextBlock Text="{Binding FixSuccessDetail}"
                                           Foreground="{DynamicResource GS.Text.Secondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Reboot Prompt Banner (amber) -->
                    <Border Background="#1C1105" CornerRadius="8" Padding="14" Margin="0,0,0,12"
                            BorderBrush="#F59E0B" BorderThickness="1"
                            Style="{StaticResource AnimatedBannerStyle}"
                            Visibility="{Binding ShowRebootPrompt, Converter={StaticResource BoolToVisibility}}">
                        <DockPanel>
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        VerticalAlignment="Center" Margin="10,0,0,0">
                                <Button Content="Restart Now" Padding="10,5"
                                        Background="#F59E0B" Foreground="#0D1117"
                                        BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                        Margin="0,0,8,0"
                                        Click="OnRestartNowClicked"/>
                                <Button Content="Later" Padding="10,5"
                                        Background="Transparent"
                                        Foreground="{DynamicResource GS.Text.Secondary}"
                                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                        Cursor="Hand"
                                        Click="OnDismissRebootPrompt"/>
                            </StackPanel>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock FontWeight="Bold" Foreground="#F59E0B" FontSize="13">
                                    <Run Text="Restart required for "/><Run Text="{Binding RebootFixName, Mode=OneWay}" FontWeight="Bold"/>
                                </TextBlock>
                                <TextBlock Text="This fix modifies a system setting that only takes effect after a restart."
                                           Foreground="{DynamicResource GS.Text.Secondary}" FontSize="12"
                                           TextWrapping="Wrap" Margin="0,4,0,0"/>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Post-Reboot Comparison Section -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="16" Margin="0,0,0,16"
                            BorderBrush="#4ADE80" BorderThickness="1"
                            Style="{StaticResource AnimatedBannerStyle}"
                            Visibility="{Binding HasPendingRebootComparison, Converter={StaticResource BoolToVisibility}}">
                        <StackPanel>
                            <TextBlock Text="Post-Reboot Results" FontSize="15" FontWeight="Bold"
                                       Foreground="#4ADE80" Margin="0,0,0,8"/>
                            <TextBlock Text="You applied fixes that required a restart. Run a 30-second scan to see before and after results."
                                       Foreground="{DynamicResource GS.Text.Secondary}" FontSize="12"
                                       TextWrapping="Wrap" Margin="0,0,0,12"/>
                            <Button Content="Run Comparison Scan" Padding="14,6"
                                    Background="#4ADE80" Foreground="#0D1117"
                                    BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                    HorizontalAlignment="Left" Margin="0,0,0,10"
                                    Click="OnRun30sClicked"/>
                            <ItemsControl ItemsSource="{Binding RebootComparisonLines}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding}" FontFamily="Consolas" FontSize="12"
                                                   Foreground="{DynamicResource GS.Text.Primary}" Margin="0,2"/>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Section 1: Health Banner + Live Monitor -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="16" Margin="0,0,0,16"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <!-- Health status -->
                            <DockPanel Margin="0,0,0,12">
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock FontSize="18" FontWeight="Bold"
                                               Text="{Binding HealthStatus}"
                                               Foreground="{Binding HealthColor}"/>
                                    <TextBlock Text="{Binding HealthExplanation}"
                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                               TextWrapping="Wrap" MaxWidth="600" Margin="0,4,0,0"/>
                                </StackPanel>
                                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                                            HorizontalAlignment="Right" VerticalAlignment="Top">
                                    <Button Content="Start" Padding="14,6"
                                            Background="#4ADE80" Foreground="#0D1117"
                                            BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding CanStart, Converter={StaticResource BoolToVisibility}}"
                                            Click="OnStartClicked"/>
                                    <Button Content="Stop" Padding="14,6"
                                            Background="#EF4444" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                            Margin="0,0,6,0"
                                            Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}"
                                            Click="OnStopClicked"/>
                                    <Button Content="Run 30s" Padding="14,6"
                                            Background="#3B82F6" Foreground="White"
                                            BorderThickness="0" FontWeight="SemiBold" Cursor="Hand"
                                            Visibility="{Binding CanStart, Converter={StaticResource BoolToVisibility}}"
                                            Click="OnRun30sClicked"/>
                                </StackPanel>
                            </DockPanel>

                            <!-- Capture time indicator -->
                            <TextBlock Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}"
                                       Foreground="{DynamicResource GS.Text.Secondary}" FontSize="12"
                                       Margin="0,0,0,8">
                                <Run Text="Capturing: "/><Run Text="{Binding CaptureTimeText, Mode=OneWay}"/>
                            </TextBlock>

                            <!-- Column headers -->
                            <Grid Margin="8,0,8,4" Visibility="{Binding IsCapturing, Converter={StaticResource BoolToVisibility}}">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="80"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="90"/>
                                    <ColumnDefinition Width="70"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="DRIVER" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                <TextBlock Grid.Column="1" Text="COUNT" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right"
                                           Cursor="Help"
                                           ToolTip="How many times this driver interrupted your CPU during the capture."
                                           Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}"/>
                                <TextBlock Grid.Column="2" Text="HIGHEST" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right"
                                           Cursor="Help">
                                    <TextBlock.ToolTip>
                                        <TextBlock MaxWidth="320" TextWrapping="Wrap">
This is how long this driver locked up your CPU, in microseconds (&#x00B5;s).

&#x2022; Under 500 &#x00B5;s &#x2014; Healthy, no impact on games
&#x2022; 500&#x2013;2,000 &#x00B5;s &#x2014; Elevated, might cause minor audio glitches
&#x2022; 2,000&#x2013;4,000 &#x00B5;s &#x2014; Problematic, will cause stuttering
&#x2022; Over 4,000 &#x00B5;s &#x2014; Severe, your game freezes every time this runs
                                        </TextBlock>
                                    </TextBlock.ToolTip>
                                </TextBlock>
                                <TextBlock Grid.Column="3" Text="AVERAGE" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right"
                                           Cursor="Help"
                                           ToolTip="Average time per interrupt. A high average means consistently bad performance, not just occasional spikes."
                                           Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}"/>
                                <TextBlock Grid.Column="4" Text="STATUS" FontSize="10" FontWeight="Bold"
                                           Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right"/>
                            </Grid>

                            <!-- Driver table -->
                            <ItemsControl ItemsSource="{Binding DriverRows}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type vm:DriverRowViewModel}">
                                        <Border Padding="8,6" Margin="0,1"
                                                Background="#0F172A" CornerRadius="4">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="80"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="90"/>
                                                    <ColumnDefinition Width="70"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Driver name -->
                                                <StackPanel Grid.Column="0">
                                                    <TextBlock Text="{Binding FriendlyName}"
                                                               Foreground="{DynamicResource GS.Text.Primary}"
                                                               FontWeight="SemiBold" FontSize="13"/>
                                                    <TextBlock Text="{Binding DriverFileName}"
                                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                                               FontSize="11"
                                                               Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}"/>
                                                </StackPanel>

                                                <!-- DPC Count -->
                                                <TextBlock Grid.Column="1" Text="{Binding DpcCount, StringFormat=N0}"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           FontSize="12"
                                                           Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}"/>

                                                <!-- Highest -->
                                                <TextBlock Grid.Column="2" Text="{Binding HighestUsFormatted}"
                                                           Foreground="{DynamicResource GS.Text.Primary}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           FontWeight="SemiBold" FontSize="12"/>

                                                <!-- Average -->
                                                <TextBlock Grid.Column="3" Text="{Binding AvgUsFormatted}"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           VerticalAlignment="Center" HorizontalAlignment="Right"
                                                           FontSize="12"
                                                           Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}"/>

                                                <!-- Status badge -->
                                                <Border Grid.Column="4" CornerRadius="4" Padding="6,2"
                                                        HorizontalAlignment="Right" VerticalAlignment="Center"
                                                        Background="#1C4A2E">
                                                    <TextBlock Text="{Binding StatusText}" FontSize="11"
                                                               FontWeight="SemiBold" HorizontalAlignment="Center"
                                                               Foreground="{Binding StatusColor}"/>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Section 2: Diagnosed Issues -->
                    <StackPanel Visibility="{Binding ShowDiagnosedIssues, Converter={StaticResource BoolToVisibility}}">
                        <TextBlock Text="Diagnosed Issues" FontSize="18" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,12"/>

                        <ItemsControl ItemsSource="{Binding DiagnosedIssues}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate DataType="{x:Type vm:DiagnosedIssueViewModel}">
                                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                                            Padding="16" Margin="0,0,0,10"
                                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                                        <StackPanel>
                                            <!-- Header: severity + driver name + peak -->
                                            <DockPanel Margin="0,0,0,8">
                                                <Border CornerRadius="4" Padding="8,2" DockPanel.Dock="Left"
                                                        VerticalAlignment="Center" Margin="0,0,8,0"
                                                        Background="#7F1D1D">
                                                    <TextBlock Text="{Binding SeverityText}" FontSize="11"
                                                               FontWeight="Bold" Foreground="{Binding SeverityColor}"/>
                                                </Border>
                                                <TextBlock Foreground="{DynamicResource GS.Text.Primary}"
                                                           FontSize="15" FontWeight="SemiBold"
                                                           VerticalAlignment="Center"
                                                           Text="{Binding FriendlyName}"/>
                                                <TextBlock Text="{Binding PeakFormatted}"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                           VerticalAlignment="Center" FontSize="13"/>
                                            </DockPanel>

                                            <!-- What's wrong -->
                                            <TextBlock Text="{Binding SimpleExplanation}"
                                                       Foreground="{DynamicResource GS.Text.Primary}"
                                                       TextWrapping="Wrap" Margin="0,0,0,6"/>

                                            <!-- Gaming impact -->
                                            <TextBlock Foreground="#F59E0B" TextWrapping="Wrap" Margin="0,0,0,10"
                                                       FontWeight="SemiBold" FontSize="12">
                                                <Run Text="THIS IS WHY: "/><Run Text="{Binding GamingImpact, Mode=OneWay}"/>
                                            </TextBlock>

                                            <!-- Auto fixes -->
                                            <ItemsControl ItemsSource="{Binding AutoFixes}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Background="#0F172A" CornerRadius="6"
                                                                Padding="12" Margin="0,0,0,6">
                                                            <DockPanel>
                                                                <Button Content="Apply Fix" DockPanel.Dock="Right"
                                                                        Padding="12,6" Margin="12,0,0,0"
                                                                        Background="#4ADE80" Foreground="#0D1117"
                                                                        BorderThickness="0" FontWeight="SemiBold"
                                                                        Cursor="Hand" VerticalAlignment="Top"
                                                                        Tag="{Binding}"
                                                                        Click="OnApplyFixClicked"/>
                                                                <StackPanel>
                                                                    <TextBlock Text="{Binding Name}"
                                                                               Foreground="{DynamicResource GS.Text.Primary}"
                                                                               FontWeight="SemiBold" FontSize="13"/>
                                                                    <TextBlock Text="{Binding SimpleExplanation}"
                                                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                                                               TextWrapping="Wrap" Margin="0,4,0,4"
                                                                               FontSize="12"/>
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <!-- Technical mode: "Impact: High" -->
                                                                        <TextBlock FontSize="11" Foreground="#94A3B8"
                                                                                   Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource InverseBoolToVisibility}}">
                                                                            <Run Text="Impact: "/><Run Text="{Binding Impact, Mode=OneWay}"/>
                                                                        </TextBlock>
                                                                        <!-- Simple mode: "Expected: Big improvement" -->
                                                                        <TextBlock FontSize="11" Foreground="#4ADE80"
                                                                                   Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}">
                                                                            <Run Text="Expected: "/><Run Text="{Binding Impact, Mode=OneWay, Converter={StaticResource ImpactToFriendly}}" FontWeight="SemiBold"/>
                                                                        </TextBlock>
                                                                        <TextBlock Text=" · Reboot required" FontSize="11"
                                                                                   Foreground="#F59E0B"
                                                                                   Visibility="{Binding RequiresReboot, Converter={StaticResource BoolToVisibility}}"/>
                                                                    </StackPanel>
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>

                                            <!-- Manual fixes -->
                                            <Expander Header="How to Fix Manually" Margin="0,6,0,0"
                                                      Foreground="{DynamicResource GS.Text.Secondary}">
                                                <ItemsControl ItemsSource="{Binding ManualFixes}" Margin="8,8,0,0">
                                                    <ItemsControl.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding}" TextWrapping="Wrap"
                                                                       Foreground="{DynamicResource GS.Text.Secondary}"
                                                                       FontSize="12" Margin="0,0,0,4"/>
                                                        </DataTemplate>
                                                    </ItemsControl.ItemTemplate>
                                                </ItemsControl>
                                            </Expander>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Section 3: Quick Fixes Toolbar -->
                    <TextBlock Text="Quick Fixes" FontSize="18" FontWeight="Bold"
                               Foreground="{DynamicResource GS.Text.Primary}" Margin="0,8,0,12"/>

                    <ItemsControl ItemsSource="{Binding QuickFixes}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Columns="2"/>
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type vm:QuickFixViewModel}">
                                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                                        Padding="14" Margin="0,0,8,8" Cursor="Hand"
                                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                        MouseLeftButtonUp="OnToggleQuickFixClicked">
                                    <Border.ToolTip>
                                        <StackPanel MaxWidth="350">
                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" FontSize="13"
                                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding SimpleTooltip}" TextWrapping="Wrap" FontSize="12"
                                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,6"/>
                                            <TextBlock Text="{Binding TechnicalTooltip}" TextWrapping="Wrap" FontSize="11"
                                                       Foreground="#94A3B8" Margin="0,0,0,6"/>
                                            <TextBlock Text="Reboot required after applying" FontSize="11"
                                                       Foreground="#F59E0B"
                                                       Visibility="{Binding RequiresReboot, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBlock FontSize="11" Foreground="#94A3B8">
                                                <Run Text="Current state: "/><Run Text="{Binding StateText, Mode=OneWay}"/>
                                            </TextBlock>
                                        </StackPanel>
                                    </Border.ToolTip>
                                    <DockPanel>
                                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center"
                                                    HorizontalAlignment="Right">
                                            <Border CornerRadius="4" Padding="8,3"
                                                    Background="#1E293B">
                                                <TextBlock Text="{Binding StateText}" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="#94A3B8"/>
                                            </Border>
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}"
                                                       Foreground="{DynamicResource GS.Text.Primary}"
                                                       FontWeight="SemiBold" FontSize="13"/>
                                            <TextBlock Text="{Binding SimpleTooltip}"
                                                       Foreground="{DynamicResource GS.Text.Secondary}"
                                                       TextWrapping="Wrap" FontSize="11" Margin="0,4,0,0"
                                                       MaxHeight="36" TextTrimming="CharacterEllipsis"/>
                                            <TextBlock Text="Reboot required" FontSize="10"
                                                       Foreground="#F59E0B" Margin="0,4,0,0"
                                                       Visibility="{Binding RequiresReboot, Converter={StaticResource BoolToVisibility}}"/>
                                            <TextBlock FontSize="10" Foreground="#4ADE80" Margin="0,3,0,0"
                                                       Text="{Binding ImpactFriendly}"
                                                       Visibility="{Binding DataContext.IsSimpleMode, RelativeSource={RelativeSource AncestorType=Page}, Converter={StaticResource BoolToVisibility}}"/>
                                        </StackPanel>
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                </StackPanel>
            </ScrollViewer>
        </DockPanel>
    </Grid>
</Page>
