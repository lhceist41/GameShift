<Page x:Class="GameShift.App.Views.Pages.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
        <BooleanToVisibilityConverter x:Key="AdvancedVisibility"/>

        <!-- Card Text Crossfade Animation (300ms, CubicEase) — Feature #5 -->
        <Style x:Key="AnimatedTextStyle" TargetType="TextBlock">
            <Style.Triggers>
                <EventTrigger RoutedEvent="Binding.TargetUpdated">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                From="0.5" To="1.0" Duration="0:0:0.3">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

        <!-- Alert Banner Slide Animation (200ms, CubicEase) -->
        <Style x:Key="AnimatedBannerStyle" TargetType="Border">
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-30"/>
                </Setter.Value>
            </Setter>
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <Trigger Property="Visibility" Value="Visible">
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                    From="0" To="1" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                    From="-30" To="0" Duration="0:0:0.2">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Activity Feed Fade-In Animation (150ms, CubicEase) -->
        <Style x:Key="FadeInItemStyle" TargetType="ContentPresenter">
            <Setter Property="Opacity" Value="0"/>
            <Style.Triggers>
                <EventTrigger RoutedEvent="Loaded">
                    <BeginStoryboard>
                        <Storyboard>
                            <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                From="0" To="1" Duration="0:0:0.15">
                                <DoubleAnimation.EasingFunction>
                                    <CubicEase EasingMode="EaseOut"/>
                                </DoubleAnimation.EasingFunction>
                            </DoubleAnimation>
                        </Storyboard>
                    </BeginStoryboard>
                </EventTrigger>
            </Style.Triggers>
        </Style>

    </Page.Resources>
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  helpers:ScrollHelper.FixScrolling="True">
        <StackPanel Margin="24">

            <!-- Easy Mode toggle — top-right -->
            <CheckBox x:Name="EasyModeToggle"
                      IsChecked="{Binding IsEasyMode, Mode=TwoWay}"
                      HorizontalAlignment="Right" Margin="0,0,0,12"
                      Foreground="{DynamicResource GS.Text.Secondary}"
                      FontSize="12" Cursor="Hand"
                      ToolTip="Simplify the interface - show only Dashboard and Settings">
                <TextBlock Text="Easy Mode"
                           Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12"/>
            </CheckBox>

            <!-- ═══════════════════════════════════════════════════════════
                 Alert Banners Section
                 Appears at top above the card grid — conditional visibility
                 ═══════════════════════════════════════════════════════════ -->

            <!-- Alert banners — Advanced Mode only -->
            <StackPanel Visibility="{Binding IsAdvancedMode, Converter={StaticResource AdvancedVisibility}}">

            <!-- VBS/HVCI Banner — amber (warning: VBS enabled, perf cost) or red (error: VBS disabled + AC conflict) -->
            <Border x:Name="VbsBanner" CornerRadius="8" Padding="15" Margin="0,0,0,12"
                    Background="{DynamicResource GS.Badge.Warning.Bg}"
                    BorderBrush="{DynamicResource GS.Status.Warning}" BorderThickness="1"
                    Visibility="{Binding Vbs.ShowVbsBanner, Converter={StaticResource BoolToVisibility}}">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource AnimatedBannerStyle}">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding Vbs.VbsBannerSeverity}" Value="error">
                                <Setter Property="Background" Value="{DynamicResource GS.Badge.Error.Bg}"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource GS.Status.Error}"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0">
                        <!-- Warning mode: Disable & Reboot button (only when NOT conflict) -->
                        <Button Content="Disable &amp; Reboot" Padding="10,4"
                                Background="{DynamicResource GS.Status.Warning}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnDisableVbsClicked" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Vbs.IsVbsConflict}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <!-- Conflict mode: Re-enable & Reboot button (only when IS conflict) -->
                        <Button Content="Re-enable &amp; Reboot" Padding="10,4"
                                Background="{DynamicResource GS.Status.Error}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnReEnableVbsClicked" Margin="0,0,8,0">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Vbs.IsVbsConflict}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                        <Button Content="Dismiss" Padding="10,4"
                                Background="{DynamicResource GS.Surface.Card}"
                                Foreground="{DynamicResource GS.Text.Primary}"
                                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                Cursor="Hand" FontSize="12"
                                Click="OnDismissVbsClicked"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <!-- Title switches between "Performance Warning" and "Anti-Cheat Conflict" -->
                        <TextBlock FontWeight="Bold" FontSize="13">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="Performance Warning"/>
                                    <Setter Property="Foreground" Value="{DynamicResource GS.Status.Warning}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Vbs.VbsBannerSeverity}" Value="error">
                                            <Setter Property="Text" Value="Anti-Cheat Conflict"/>
                                            <Setter Property="Foreground" Value="{DynamicResource GS.Status.Error}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding Vbs.VbsBannerMessage, Mode=OneWay}"
                                   FontSize="12" Foreground="{DynamicResource GS.Text.Primary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- DPC Spike Alert Banner (red) — with Troubleshoot + Dismiss buttons -->
            <Border Background="{DynamicResource GS.Badge.Error.Bg}"
                    CornerRadius="8" Padding="15" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource GS.Status.Error}" BorderThickness="1"
                    Visibility="{Binding Dpc.ShowDpcSpikeAlert, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource AnimatedBannerStyle}">
                <DockPanel>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="10,0,0,0">
                        <Button Content="Troubleshoot" Padding="10,4"
                                Background="{DynamicResource GS.Status.Error}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnTroubleshootDpcClicked" Margin="0,0,8,0"/>
                        <Button Content="Open DPC Doctor" Padding="10,4"
                                Background="{DynamicResource GS.Accent.Primary}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnOpenDpcDoctorClicked" Margin="0,0,8,0"/>
                        <Button Content="Dismiss" Padding="10,4"
                                Background="{DynamicResource GS.Surface.Card}"
                                Foreground="{DynamicResource GS.Text.Primary}"
                                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                Cursor="Hand" FontSize="12"
                                Click="OnDismissDpcSpikeClicked"/>
                    </StackPanel>
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="DPC Latency Spike" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Status.Error}" FontSize="13"/>
                        <TextBlock Text="{Binding Dpc.DpcSpikeAlertMessage, Mode=OneWay}"
                                   FontSize="12" Foreground="{DynamicResource GS.Text.Primary}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- DPC Troubleshooter Results Panel (inline, below spike banner) -->
            <Border CornerRadius="8" Padding="15" Margin="0,0,0,12"
                    Background="{DynamicResource GS.Surface.Card}"
                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                    Visibility="{Binding Dpc.ShowTroubleshooter, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource AnimatedBannerStyle}">
                <StackPanel>
                    <!-- Header row: title + summary + Re-scan button -->
                    <DockPanel Margin="0,0,0,8">
                        <Button DockPanel.Dock="Right" Content="Re-scan" Padding="8,3"
                                Background="{DynamicResource GS.Surface.Base}"
                                Foreground="{DynamicResource GS.Text.Primary}"
                                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                Cursor="Hand" FontSize="11"
                                IsEnabled="{Binding Dpc.CanRescan}"
                                Click="OnRescanDpcClicked"/>
                        <StackPanel VerticalAlignment="Center">
                            <TextBlock Text="DPC Troubleshooter" FontWeight="Bold" FontSize="14"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="{Binding Dpc.AnalysisSummary, Mode=OneWay}" FontSize="12"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </DockPanel>

                    <!-- Analyzing state: indeterminate progress bar -->
                    <ProgressBar IsIndeterminate="True" Height="4" Margin="0,0,0,8"
                                 Foreground="{DynamicResource GS.Accent.Primary}"
                                 Background="{DynamicResource GS.Surface.Base}">
                        <ProgressBar.Style>
                            <Style TargetType="ProgressBar">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding Dpc.IsAnalyzing}" Value="True">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </ProgressBar.Style>
                    </ProgressBar>

                    <!-- Results list: driver cards -->
                    <ItemsControl ItemsSource="{Binding Dpc.TroubleshooterResults}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="{DynamicResource GS.Surface.Base}"
                                        CornerRadius="6" Padding="12,10" Margin="0,0,0,6"
                                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                                    <StackPanel>
                                        <!-- Driver header: filename + component name + severity badge -->
                                        <DockPanel Margin="0,0,0,4">
                                            <!-- Severity badge -->
                                            <Border DockPanel.Dock="Right" CornerRadius="4" Padding="6,2"
                                                    VerticalAlignment="Center">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="#555"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Offender.Severity}" Value="High">
                                                                <Setter Property="Background" Value="{DynamicResource GS.Status.Error}"/>
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding Offender.Severity}" Value="Medium">
                                                                <Setter Property="Background" Value="{DynamicResource GS.Status.Warning}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <TextBlock Text="{Binding Offender.Severity}" FontSize="10"
                                                           Foreground="White" FontWeight="SemiBold"/>
                                            </Border>
                                            <StackPanel VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding DriverFileName}" FontSize="13" FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GS.Text.Primary}"/>
                                                    <TextBlock Text="{Binding FileVersion, StringFormat=' (v{0})'}" FontSize="11"
                                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                                               VerticalAlignment="Center" Margin="4,0,0,0"/>
                                                </StackPanel>
                                                <TextBlock Text="{Binding Offender.ComponentName}" FontSize="12"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"/>
                                            </StackPanel>
                                        </DockPanel>

                                        <!-- Problem description -->
                                        <TextBlock Text="{Binding Offender.Problem}" FontSize="12"
                                                   Foreground="{DynamicResource GS.Text.Secondary}"
                                                   TextWrapping="Wrap" Margin="0,2,0,6"/>

                                        <!-- Fix steps as numbered list -->
                                        <ItemsControl ItemsSource="{Binding Offender.FixSteps}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <StackPanel Orientation="Horizontal" Margin="0,1,0,1">
                                                        <TextBlock Text="&#x2022;" FontSize="12" Margin="0,0,6,0"
                                                                   Foreground="{DynamicResource GS.Accent.Primary}"
                                                                   VerticalAlignment="Top"/>
                                                        <TextBlock Text="{Binding}" FontSize="12"
                                                                   Foreground="{DynamicResource GS.Text.Primary}"
                                                                   TextWrapping="Wrap"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Empty state (no offenders found, analysis complete) -->
                    <TextBlock FontSize="12" Foreground="{DynamicResource GS.Text.Secondary}"
                               Margin="0,4,0,0">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <MultiDataTrigger>
                                        <MultiDataTrigger.Conditions>
                                            <Condition Binding="{Binding Dpc.TroubleshooterResults.Count}" Value="0"/>
                                            <Condition Binding="{Binding Dpc.IsAnalyzing}" Value="False"/>
                                        </MultiDataTrigger.Conditions>
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </MultiDataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                        <Run Text="No known DPC offenders detected. Your drivers look clean."/>
                        <LineBreak/>
                        <Run Text="If you still experience latency spikes, try updating all drivers to their latest versions."
                             Foreground="{DynamicResource GS.Text.Disabled}"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- Update Available Banner — three states: idle / downloading / ready -->
            <Border Background="{DynamicResource GS.Surface.Card}"
                    CornerRadius="8" Padding="15" Margin="0,0,0,12"
                    BorderBrush="{DynamicResource GS.Accent.Primary}" BorderThickness="1"
                    Visibility="{Binding Update.ShowUpdateBanner, Converter={StaticResource BoolToVisibility}}"
                    Style="{StaticResource AnimatedBannerStyle}">
                <DockPanel>
                    <!-- Right-side action area -->
                    <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" Margin="10,0,0,0">

                        <!-- State 1: Download button (idle) -->
                        <Button Content="Download" Padding="10,4"
                                Background="{DynamicResource GS.Accent.Primary}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnUpdateDownloadClicked">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.IsDownloading}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Update.IsUpdateReady}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>

                        <!-- State 2: Progress bar + cancel (downloading) -->
                        <StackPanel Orientation="Horizontal">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.IsDownloading}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <ProgressBar Width="120" Height="16" Minimum="0" Maximum="100"
                                         Value="{Binding Update.DownloadProgress, Mode=OneWay}"
                                         VerticalAlignment="Center"
                                         Foreground="{DynamicResource GS.Accent.Primary}"
                                         Background="{DynamicResource GS.Surface.Base}"/>
                            <TextBlock Text="{Binding Update.DownloadProgress, Mode=OneWay, StringFormat={}{0:F0}%}"
                                       FontSize="12" VerticalAlignment="Center" Margin="6,0,0,0"
                                       Foreground="{DynamicResource GS.Text.Primary}" MinWidth="32"/>
                            <Button Content="Cancel" Padding="6,2"
                                    Background="Transparent"
                                    Foreground="{DynamicResource GS.Text.Secondary}"
                                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                    Cursor="Hand" FontSize="11" Margin="8,0,0,0"
                                    VerticalAlignment="Center"
                                    Click="OnUpdateCancelClicked"/>
                        </StackPanel>

                        <!-- State 3: Restart Now button (download complete) -->
                        <Button Content="Restart Now" Padding="10,4"
                                Background="{DynamicResource GS.Accent.Primary}" Foreground="White"
                                BorderThickness="0" Cursor="Hand" FontSize="12"
                                Click="OnUpdateRestartClicked">
                            <Button.Style>
                                <Style TargetType="Button">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.IsUpdateReady}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                        </Button>
                    </StackPanel>

                    <!-- Left side: title + message/status -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="Update Available" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Accent.Primary}" FontSize="13"/>
                        <TextBlock FontSize="12" Foreground="{DynamicResource GS.Text.Primary}" TextWrapping="Wrap">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="{Binding Update.UpdateMessage, Mode=OneWay}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Update.IsDownloading}" Value="True">
                                            <Setter Property="Text" Value="{Binding Update.DownloadStatusText, Mode=OneWay}"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding Update.IsUpdateReady}" Value="True">
                                            <Setter Property="Text" Value="{Binding Update.DownloadStatusText, Mode=OneWay}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </DockPanel>
            </Border>

            </StackPanel> <!-- End alert banners (Advanced Mode only) -->

            <!-- ═══════════════════════════════════════════════════════════
                 Hero Section — One-Click Optimize
                 ═══════════════════════════════════════════════════════════ -->
            <Border Background="{DynamicResource GS.Surface.Card}"
                    CornerRadius="12" Padding="32,28"
                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                    Margin="0,0,0,24">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: Status + preview -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <Ellipse Width="12" Height="12" Margin="0,0,10,0"
                                     VerticalAlignment="Center"
                                     Fill="{Binding Hero.HeroStatusBrush}"/>
                            <TextBlock Text="{Binding Hero.HeroStatusText}"
                                       Style="{DynamicResource GS.Text.Hero}"
                                       FontSize="24"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding Hero.HeroSubtitleText}"
                                   FontSize="13"
                                   Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="22,0,0,0"/>
                        <!-- Preview: clickable line showing what will be applied -->
                        <TextBlock x:Name="OptimizationPreviewLink"
                                   Text="{Binding Hero.HeroPreviewText}"
                                   FontSize="12" Cursor="Hand"
                                   Foreground="{DynamicResource GS.Status.Info}"
                                   Margin="22,8,0,0"
                                   MouseLeftButtonUp="OnOptimizationPreviewClicked"
                                   Visibility="{Binding Hero.ShowHeroPreview, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock.TextDecorations>
                                <TextDecorationCollection>
                                    <TextDecoration Location="Underline"/>
                                </TextDecorationCollection>
                            </TextBlock.TextDecorations>
                        </TextBlock>
                        <!-- Expandable preview list -->
                        <ItemsControl x:Name="PreviewList"
                                      ItemsSource="{Binding Hero.HeroPreviewItems}"
                                      Margin="22,6,0,0"
                                      Visibility="Collapsed">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <TextBlock Text="{Binding}" FontSize="12"
                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                               Margin="0,2,0,0"/>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </StackPanel>

                    <!-- Right: CTA button with pulse animation during optimize -->
                    <Grid Grid.Column="1" VerticalAlignment="Center">
                        <!-- Glow layer behind button — visible only while applying -->
                        <Border x:Name="HeroGlow" CornerRadius="10"
                                MinWidth="180" Height="48" Opacity="0"
                                IsHitTestVisible="False">
                            <Border.Background>
                                <SolidColorBrush Color="#4ADE80"/>
                            </Border.Background>
                            <Border.Effect>
                                <BlurEffect Radius="20"/>
                            </Border.Effect>
                        </Border>

                        <Button x:Name="HeroButton"
                                Command="{Binding Hero.OptimizeNowCommand}"
                                VerticalAlignment="Center"
                                MinWidth="180" Height="48"
                                FontSize="15" FontWeight="SemiBold"
                                Cursor="Hand"
                                Style="{DynamicResource GS.Button.Hero}">
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <!-- Spinning icon during apply/revert -->
                                <TextBlock x:Name="HeroSpinner" Text="&#x21BB;"
                                           FontSize="16" Margin="0,0,8,0"
                                           VerticalAlignment="Center"
                                           Visibility="Collapsed"
                                           RenderTransformOrigin="0.5,0.5">
                                    <TextBlock.RenderTransform>
                                        <RotateTransform x:Name="SpinnerRotation" Angle="0"/>
                                    </TextBlock.RenderTransform>
                                </TextBlock>
                                <TextBlock Text="{Binding Hero.HeroButtonText}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </Grid>
            </Border>

            <!-- ═══════════════════════════════════════════════════════════
                 Card Grid — 2x2 UniformGrid
                 Each card Border has Margin=8 (8+8=16px gaps between cards).
                 UniformGrid has Margin="-8" to compensate outer edges.
                 ═══════════════════════════════════════════════════════════ -->
            <UniformGrid Rows="1" Columns="2" Margin="-8,0,-8,0">

                <!-- Card 1: Game Status -->
                <Border Background="{DynamicResource GS.Surface.Card}"
                        CornerRadius="8" Padding="16" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Game Status" FontSize="12"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding StatusBrush, Mode=OneWay}"/>
                            <TextBlock Text="{Binding StatusText, Mode=OneWay, NotifyOnTargetUpdated=True}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Primary}" Style="{StaticResource AnimatedTextStyle}"/>
                        </StackPanel>
                        <TextBlock Text="{Binding ActiveGameNames, Mode=OneWay}" FontSize="13"
                                   Foreground="{DynamicResource GS.Text.Secondary}"/>
                    </StackPanel>
                </Border>

                <!-- Card 2: Optimizations -->
                <Border Background="{DynamicResource GS.Surface.Card}"
                        CornerRadius="8" Padding="16" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Optimizations" FontSize="12"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding OptimizationSummary, Mode=OneWay, NotifyOnTargetUpdated=True}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,4" Style="{StaticResource AnimatedTextStyle}"/>
                        <TextBlock Text="System optimizations" FontSize="13"
                                   Foreground="{DynamicResource GS.Text.Secondary}"/>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Advanced cards — Advanced Mode only -->
            <UniformGrid Rows="1" Columns="4" Margin="-8,8,-8,0"
                         Visibility="{Binding IsAdvancedMode, Converter={StaticResource AdvancedVisibility}}">

                <!-- Card 3: DPC Latency -->
                <Border Background="{DynamicResource GS.Surface.Card}"
                        CornerRadius="8" Padding="16" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="DPC Latency" FontSize="12"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                            <Ellipse Width="10" Height="10" Margin="0,0,8,0" VerticalAlignment="Center"
                                     Fill="{Binding Dpc.DpcLatencyBrush, Mode=OneWay}"/>
                            <TextBlock Text="{Binding Dpc.DpcLatencyText, Mode=OneWay, NotifyOnTargetUpdated=True}" FontSize="22" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Primary}" Style="{StaticResource AnimatedTextStyle}"/>
                        </StackPanel>
                        <!-- Average latency or inactive placeholder -->
                        <TextBlock FontSize="13" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dpc.ShowDpcIndicator}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="Avg: "/>
                            <Run Text="{Binding Dpc.AverageDpcLatency, Mode=OneWay, StringFormat={}{0:F0}}"/>
                            <Run Text="µs"/>
                        </TextBlock>
                        <TextBlock Text="Monitoring inactive" FontSize="13"
                                   Foreground="{DynamicResource GS.Text.Disabled}" Margin="0,0,0,4">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding Dpc.ShowDpcIndicator}" Value="False">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <!-- Sparkline: 120x32 Canvas with Polyline bound to SparklinePoints -->
                        <Canvas Width="120" Height="32" Margin="0,8,0,0"
                                ClipToBounds="True" HorizontalAlignment="Left">
                            <Polyline Points="{Binding Dpc.SparklinePoints, Mode=OneWay}"
                                      Stroke="{Binding Dpc.SparklineBrush, Mode=OneWay}"
                                      StrokeThickness="1.5" Fill="Transparent"/>
                        </Canvas>
                    </StackPanel>
                </Border>

                <!-- Card 5: GPU -->
                <Border Background="{DynamicResource GS.Surface.Card}"
                        CornerRadius="8" Padding="16" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GPU" FontSize="12"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <TextBlock Text="{Binding GpuInfo, Mode=OneWay}" FontSize="22" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,0,4"/>
                        <TextBlock Text="{Binding GpuOptimizationState, Mode=OneWay}" FontSize="13"
                                   Foreground="{DynamicResource GS.Text.Secondary}"/>
                    </StackPanel>
                </Border>

                <!-- Card 5: Network Ping -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="Network Ping" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}"/>
                            <Ellipse Width="8" Height="8" Fill="{Binding Ping.PingBrush}"
                                     DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </DockPanel>
                        <TextBlock Text="{Binding Ping.PingText}" FontSize="20" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <Polyline Points="{Binding Ping.PingSparklinePoints}" Stroke="{Binding Ping.PingBrush}"
                                  StrokeThickness="1.5" Width="120" Height="32" Stretch="None"
                                  VerticalAlignment="Bottom" Margin="0,4,0,0"/>
                        <TextBlock Text="{Binding Ping.PingStats}" FontSize="10"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Card 6: Performance -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Performance" FontSize="10" FontWeight="Bold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="CPU" FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Width="30"/>
                            <TextBlock Text="{Binding Perf.CpuText}" FontSize="14" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Accent.Primary}" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="RAM" FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Width="30"/>
                            <TextBlock Text="{Binding Perf.RamText}" FontSize="14" FontWeight="Bold"
                                       Foreground="#A78BFA" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="GPU" FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Width="30"/>
                            <TextBlock Text="{Binding Perf.GpuUtilText}" FontSize="14" FontWeight="Bold"
                                       Foreground="#FBBF24" DockPanel.Dock="Right" HorizontalAlignment="Right"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

            </UniformGrid>

            <!-- Advanced-only sections below the card grid -->
            <StackPanel Visibility="{Binding IsAdvancedMode, Converter={StaticResource AdvancedVisibility}}">

            <!-- ═══════════════════════════════════════════════════════════
                 Hardware Advisories Section
                 ═══════════════════════════════════════════════════════════ -->
            <StackPanel Margin="0,12,0,0">
                <!-- HAGS status + advisory -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="14" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border CornerRadius="4" Padding="8,3"
                                    Background="#1E293B">
                                <TextBlock Text="{Binding HagsStatus}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8"/>
                            </Border>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Hardware Accelerated GPU Scheduling (HAGS)"
                                       Foreground="{DynamicResource GS.Text.Primary}"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <!-- Advisory banner (only shown when HAGS is off on a supported GPU) -->
                            <Border Visibility="{Binding ShowHagsAdvisory, Converter={StaticResource BoolToVisibility}}"
                                    Background="#2D2006" CornerRadius="4" Padding="10,6" Margin="0,6,0,0">
                                <TextBlock Text="{Binding HagsAdvisory}" Foreground="#F59E0B"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- ReBAR / SAM status + advisory -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="14" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right">
                            <Border CornerRadius="4" Padding="8,3"
                                    Background="#1E293B">
                                <TextBlock Text="{Binding ReBarStatus}" FontSize="11" FontWeight="SemiBold"
                                           Foreground="#94A3B8"/>
                            </Border>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Resizable BAR / Smart Access Memory"
                                       Foreground="{DynamicResource GS.Text.Primary}"
                                       FontWeight="SemiBold" FontSize="13"/>
                            <!-- Advisory banner (only shown when ReBAR supported but not enabled) -->
                            <Border Visibility="{Binding ShowReBarAdvisory, Converter={StaticResource BoolToVisibility}}"
                                    Background="#2D2006" CornerRadius="4" Padding="10,6" Margin="0,6,0,0">
                                <TextBlock Text="{Binding ReBarAdvisory}" Foreground="#F59E0B"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </DockPanel>
                </Border>
            </StackPanel>

            <!-- ═══════════════════════════════════════════════════════════
                 Performance Graphs Section
                 ═══════════════════════════════════════════════════════════ -->
            <TextBlock Text="PERFORMANCE GRAPHS" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,20,0,8"/>
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <!-- CPU Graph -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="12" Margin="0,0,4,0"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="CPU" FontSize="11" FontWeight="Bold" Foreground="{DynamicResource GS.Accent.Primary}"/>
                            <TextBlock Text="{Binding Perf.CpuText}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="14" FontWeight="Bold" Foreground="{DynamicResource GS.Accent.Primary}"/>
                        </DockPanel>
                        <Polyline Points="{Binding Perf.CpuSparklinePoints}" Stroke="{DynamicResource GS.Accent.Primary}"
                                  StrokeThickness="1.5" Width="120" Height="48" Stretch="None"/>
                    </StackPanel>
                </Border>
                <!-- RAM Graph -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="12" Margin="4,0,4,0"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="RAM" FontSize="11" FontWeight="Bold" Foreground="#A78BFA"/>
                            <TextBlock Text="{Binding Perf.RamText}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="14" FontWeight="Bold" Foreground="#A78BFA"/>
                        </DockPanel>
                        <Polyline Points="{Binding Perf.RamSparklinePoints}" Stroke="#A78BFA"
                                  StrokeThickness="1.5" Width="120" Height="48" Stretch="None"/>
                    </StackPanel>
                </Border>
                <!-- GPU Graph -->
                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="12" Margin="4,0,0,0"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,4">
                            <TextBlock Text="GPU" FontSize="11" FontWeight="Bold" Foreground="#FBBF24"/>
                            <TextBlock Text="{Binding Perf.GpuUtilText}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       FontSize="14" FontWeight="Bold" Foreground="#FBBF24"/>
                        </DockPanel>
                        <Polyline Points="{Binding Perf.GpuSparklinePoints}" Stroke="#FBBF24"
                                  StrokeThickness="1.5" Width="120" Height="48" Stretch="None"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══════════════════════════════════════════════════════════
                 Session History Section
                 ═══════════════════════════════════════════════════════════ -->
            <TextBlock Text="RECENT SESSIONS" FontSize="11" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
            <ItemsControl ItemsSource="{Binding RecentSessions}" Margin="0,0,0,20">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="6"
                                Padding="12" Margin="0,0,0,6"
                                BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                            <DockPanel>
                                <StackPanel DockPanel.Dock="Left">
                                    <TextBlock Text="{Binding GameName}" FontWeight="SemiBold"
                                               Foreground="{DynamicResource GS.Text.Primary}" FontSize="13"/>
                                    <TextBlock FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,0">
                                        <Run Text="{Binding Duration, StringFormat={}{0:hh\\:mm\\:ss}, Mode=OneWay}"/>
                                        <Run Text=" | "/>
                                        <Run Text="{Binding OptimizationsApplied, Mode=OneWay}"/>
                                        <Run Text=" optimizations"/>
                                    </TextBlock>
                                </StackPanel>
                                <StackPanel DockPanel.Dock="Right" HorizontalAlignment="Right" VerticalAlignment="Center">
                                    <TextBlock FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right">
                                        <Run Text="DPC: "/>
                                        <Run Text="{Binding AvgDpcDuring, StringFormat={}{0:F0}us, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock FontSize="10" Foreground="{DynamicResource GS.Text.Secondary}" HorizontalAlignment="Right"
                                               Text="{Binding StartTime, StringFormat={}{0:MMM d h:mm tt}, Mode=OneWay}"/>
                                </StackPanel>
                            </DockPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════════════════════════════════════════════════════
                 Active Optimizations Section
                 Expandable rows with toggle switch and before/after detail
                 ═══════════════════════════════════════════════════════════ -->
            <TextBlock Text="Active Optimizations"
                       Style="{DynamicResource GS.Text.SectionHeader}"
                       Margin="0,32,0,12"/>

            <ItemsControl ItemsSource="{Binding Optimizations}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <!-- Outer border — entire row is clickable for expand/collapse -->
                        <Border Background="{DynamicResource GS.Surface.Card}"
                                CornerRadius="8"
                                Margin="0,0,0,8"
                                BorderBrush="{DynamicResource GS.Surface.Border}"
                                BorderThickness="1"
                                Cursor="Hand"
                                MouseLeftButtonUp="OnOptimizationRowClicked">
                            <StackPanel>

                                <!-- Compact row: 44px height -->
                                <Grid Height="44" Margin="16,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <!-- Status dot -->
                                    <Ellipse Grid.Column="0" Width="10" Height="10"
                                             Margin="0,0,10,0" VerticalAlignment="Center"
                                             Fill="{Binding StatusBrush}"/>

                                    <!-- Name + Status -->
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="{Binding Name}"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                                        <TextBlock Text="{Binding Status}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GS.Text.Secondary}"/>
                                    </StackPanel>

                                    <!-- Per-profile enable/disable toggle -->
                                    <!-- CheckBox styled as toggle switch; stops row click from expanding -->
                                    <CheckBox Grid.Column="2"
                                              IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center"
                                              Margin="8,0"
                                              Checked="OnOptimizationToggleChanged"
                                              Unchecked="OnOptimizationToggleChanged"/>

                                    <!-- Expand/collapse chevron -->
                                    <TextBlock Grid.Column="3"
                                               VerticalAlignment="Center"
                                               Margin="4,0,0,0"
                                               FontSize="12"
                                               Foreground="{DynamicResource GS.Text.Secondary}">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="&#x25BC;"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                        <Setter Property="Text" Value="&#x25B2;"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>

                                <!-- Expanded detail panel — animated expand/collapse (200ms, CubicEase) -->
                                <Border ClipToBounds="True"
                                        BorderBrush="{DynamicResource GS.Surface.Border}"
                                        BorderThickness="0,1,0,0">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="MaxHeight" Value="0"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsExpanded}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                    To="300" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseOut"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                    <DataTrigger.ExitActions>
                                                        <BeginStoryboard>
                                                            <Storyboard>
                                                                <DoubleAnimation Storyboard.TargetProperty="MaxHeight"
                                                                    To="0" Duration="0:0:0.2">
                                                                    <DoubleAnimation.EasingFunction>
                                                                        <CubicEase EasingMode="EaseIn"/>
                                                                    </DoubleAnimation.EasingFunction>
                                                                </DoubleAnimation>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.ExitActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel Margin="16,10,16,12">

                                        <TextBlock Text="{Binding Description}"
                                                   FontSize="12"
                                                   Foreground="{DynamicResource GS.Text.Secondary}"
                                                   TextWrapping="Wrap"
                                                   Margin="0,0,0,8"/>

                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="*"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Before -->
                                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                                <TextBlock Text="Before:" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding BeforeValue}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>

                                            <!-- After -->
                                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                                <TextBlock Text="After:" FontSize="11" FontWeight="SemiBold"
                                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                                           Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding AfterValue}"
                                                           FontSize="12"
                                                           Foreground="{DynamicResource GS.Text.Primary}"
                                                           TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Grid>
                                    </StackPanel>
                                </Border>

                            </StackPanel>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- ═══════════════════════════════════════════════════════════
                 Recent Activity Section
                 Shows last 5 events; "View All" navigates to ActivityLogPage
                 ═══════════════════════════════════════════════════════════ -->

            <!-- Section header row: title + View All link -->
            <Grid Margin="0,32,0,4">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0"
                           Text="Recent Activity"
                           Style="{DynamicResource GS.Text.SectionHeader}"/>

                <TextBlock Grid.Column="1"
                           Text="View All &#x2192;"
                           FontSize="12"
                           Foreground="{DynamicResource GS.Accent.Primary}"
                           VerticalAlignment="Center"
                           Cursor="Hand"
                           MouseLeftButtonUp="OnViewAllActivityClicked"/>
            </Grid>

            <!-- Activity feed: 5 most recent entries -->
            <ItemsControl ItemsSource="{Binding RecentActivities}" Margin="0,8,0,0"
                          ItemContainerStyle="{StaticResource FadeInItemStyle}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Background="{DynamicResource GS.Surface.Card}"
                                CornerRadius="6"
                                Padding="12,8"
                                Margin="0,0,0,6"
                                BorderBrush="{DynamicResource GS.Surface.Border}"
                                BorderThickness="1">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>

                                <TextBlock Grid.Column="0"
                                           Text="{Binding TypeIcon}"
                                           FontSize="16"
                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                           VerticalAlignment="Center"/>

                                <TextBlock Grid.Column="1"
                                           Text="{Binding Description}"
                                           FontSize="13"
                                           Foreground="{DynamicResource GS.Text.Primary}"
                                           VerticalAlignment="Center"
                                           Margin="10,0,10,0"
                                           TextWrapping="Wrap"/>

                                <TextBlock Grid.Column="2"
                                           Text="{Binding TimeAgo}"
                                           FontSize="11"
                                           Foreground="{DynamicResource GS.Text.Secondary}"
                                           VerticalAlignment="Center"/>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

            <!-- Empty state when no activities -->
            <TextBlock Text="No activity yet. Start a game to see events here."
                       FontSize="12"
                       Foreground="{DynamicResource GS.Text.Secondary}"
                       Margin="0,8,0,0">
                <TextBlock.Style>
                    <Style TargetType="TextBlock">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding RecentActivities.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </TextBlock.Style>
            </TextBlock>

            </StackPanel> <!-- End advanced-only sections -->

        </StackPanel>
    </ScrollViewer>
</Page>
