<Page x:Class="GameShift.App.Views.Pages.OptimizationsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  helpers:ScrollHelper.FixScrolling="True">
        <StackPanel Margin="24">

            <!-- Page Title -->
            <TextBlock Text="Optimizations"
                       Style="{DynamicResource GS.Text.Hero}"
                       Margin="0,0,0,8" />
            <TextBlock Text="All system optimizations and their current state"
                       Style="{DynamicResource GS.Text.Body}"
                       Foreground="{DynamicResource GS.Text.Secondary}"
                       Margin="0,0,0,12" />

            <!-- Category Legend -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#4ADE80" Margin="0,0,6,0"/>
                    <TextBlock Text="Core" FontSize="12" Foreground="{DynamicResource GS.Text.Secondary}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#A78BFA" Margin="0,0,6,0"/>
                    <TextBlock Text="Competitive" FontSize="12" Foreground="{DynamicResource GS.Text.Secondary}" VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel Orientation="Horizontal">
                    <Border Width="12" Height="12" CornerRadius="2" Background="#FBBF24" Margin="0,0,6,0"/>
                    <TextBlock Text="Advisory" FontSize="12" Foreground="{DynamicResource GS.Text.Secondary}" VerticalAlignment="Center"/>
                </StackPanel>
            </StackPanel>

            <!-- Optimization Groups -->
            <ItemsControl ItemsSource="{Binding Groups}">
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="0,0,0,32">

                            <!-- Category Header -->
                            <TextBlock Text="{Binding CategoryName}"
                                       Style="{DynamicResource GS.Text.SectionHeader}"
                                       Margin="0,0,0,4" />
                            <TextBlock Text="{Binding CategoryDescription}"
                                       FontSize="12"
                                       Foreground="{DynamicResource GS.Text.Secondary}"
                                       Margin="0,0,0,12" />

                            <!-- Optimization Items -->
                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="{DynamicResource GS.Surface.Card}"
                                                CornerRadius="8"
                                                Padding="0"
                                                Margin="0,0,0,8"
                                                BorderBrush="{DynamicResource GS.Surface.Border}"
                                                BorderThickness="1"
                                                ClipToBounds="True">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4" />
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <!-- Category color strip -->
                                                <Border Grid.Column="0"
                                                        Background="{Binding DataContext.CategoryColor, RelativeSource={RelativeSource AncestorType=ItemsControl, AncestorLevel=2}}"
                                                        CornerRadius="8,0,0,8"/>

                                                <!-- Status indicator dot -->
                                                <Ellipse Grid.Column="1"
                                                         Width="10" Height="10"
                                                         Fill="{Binding StatusBrush}"
                                                         VerticalAlignment="Center"
                                                         Margin="12,12,12,12" />

                                                <!-- Name + Description -->
                                                <StackPanel Grid.Column="2"
                                                            VerticalAlignment="Center"
                                                            Margin="0,12,0,12">
                                                    <TextBlock Text="{Binding Name}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{DynamicResource GS.Text.Primary}" />
                                                    <TextBlock Text="{Binding Description}"
                                                               FontSize="12"
                                                               Foreground="{DynamicResource GS.Text.Secondary}"
                                                               TextWrapping="Wrap"
                                                               Margin="0,2,0,0" />
                                                </StackPanel>

                                                <!-- Status badge -->
                                                <Border Grid.Column="3"
                                                        CornerRadius="12"
                                                        Padding="8,4"
                                                        VerticalAlignment="Center"
                                                        Margin="12,0,12,0">
                                                    <TextBlock Text="{Binding Status}"
                                                               FontSize="11"
                                                               FontWeight="SemiBold"
                                                               Foreground="{Binding StatusBrush}" />
                                                </Border>

                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </StackPanel>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>

        </StackPanel>
    </ScrollViewer>

</Page>
