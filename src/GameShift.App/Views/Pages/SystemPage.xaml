<Page x:Class="GameShift.App.Views.Pages.SystemPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>
    <DockPanel Margin="20">
        <!-- Header with refresh button -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="System Overview" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Primary}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <Button Content="Refresh" Padding="16,6"
                    Background="{DynamicResource GS.Accent.Primary}"
                    Foreground="White" BorderThickness="0"
                    FontWeight="SemiBold" Cursor="Hand"
                    DockPanel.Dock="Right" HorizontalAlignment="Right"
                    Click="OnRefreshClicked"/>
        </DockPanel>

        <!-- Scrollable content -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      helpers:ScrollHelper.FixScrolling="True">
            <StackPanel>
                <!-- 2x3 Hardware Info Grid -->
                <UniformGrid Rows="2" Columns="3" Margin="0,0,0,20">
                    <!-- OS Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="0,0,8,8"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="OPERATING SYSTEM" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding OsCaption}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding OsVersion}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- CPU Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="4,0,4,8"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="PROCESSOR" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding CpuName}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding CpuDetails}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- GPU Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="8,0,0,8"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="GRAPHICS" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding GpuName}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding GpuDetails}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- RAM Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="0,8,8,0"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="MEMORY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding RamTotal}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="{Binding RamDetails}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Storage Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="4,8,4,0"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="STORAGE" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding StorageSummary}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Text="{Binding StorageDetails}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- Display Card -->
                    <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                            Padding="15" Margin="8,8,0,0"
                            BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                        <StackPanel>
                            <TextBlock Text="DISPLAY" FontSize="10" FontWeight="Bold"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>
                            <TextBlock Text="{Binding DisplayResolution}" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="{Binding DisplayDetails}" FontSize="11"
                                       Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <!-- Windows Gaming Features -->
                <TextBlock Text="WINDOWS GAMING FEATURES" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Game Mode" Foreground="{DynamicResource GS.Text.Primary}"
                                       VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Background="{DynamicResource GS.Surface.Base}" CornerRadius="4" Padding="8,3">
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Disabled"/>
                                            <Setter Property="Foreground" Value="{DynamicResource GS.Text.Secondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GameModeEnabled}" Value="True">
                                                    <Setter Property="Text" Value="Enabled"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource GS.Accent.Primary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="Game Bar" Foreground="{DynamicResource GS.Text.Primary}"
                                       VerticalAlignment="Center"/>
                            <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Background="{DynamicResource GS.Surface.Base}" CornerRadius="4" Padding="8,3">
                                <TextBlock FontSize="11" FontWeight="SemiBold">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Text" Value="Disabled"/>
                                            <Setter Property="Foreground" Value="{DynamicResource GS.Text.Secondary}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding GameBarEnabled}" Value="True">
                                                    <Setter Property="Text" Value="Enabled"/>
                                                    <Setter Property="Foreground" Value="{DynamicResource GS.Accent.Primary}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </Border>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Temperature Section (Phase F placeholder) -->
                <TextBlock Text="TEMPERATURE" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <TextBlock Text="CPU Temperature" Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="{Binding CpuTemp}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       Foreground="{Binding CpuTempBrush}" FontWeight="SemiBold"/>
                        </DockPanel>
                        <DockPanel>
                            <TextBlock Text="GPU Temperature" Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="{Binding GpuTemp}" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       Foreground="{Binding GpuTempBrush}" FontWeight="SemiBold"/>
                        </DockPanel>
                    </StackPanel>
                </Border>

                <!-- Top Processes -->
                <TextBlock Text="TOP PROCESSES (BY CPU TIME)" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding TopProcesses}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,6">
                                    <TextBlock DockPanel.Dock="Left" Width="180"
                                               Foreground="{DynamicResource GS.Text.Primary}"
                                               TextTrimming="CharacterEllipsis">
                                        <Run Text="{Binding Name, Mode=OneWay}"/>
                                    </TextBlock>
                                    <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                               Foreground="{DynamicResource GS.Text.Secondary}" FontSize="11">
                                        <Run Text="{Binding MemoryMB, Mode=OneWay, StringFormat={}{0} MB}"/>
                                    </TextBlock>
                                    <TextBlock Foreground="{DynamicResource GS.Text.Secondary}" FontSize="11">
                                        <Run Text="PID"/>
                                        <Run Text="{Binding Pid, Mode=OneWay}"/>
                                        <Run Text=" | CPU"/>
                                        <Run Text="{Binding CpuSeconds, Mode=OneWay, StringFormat={}{0:F1}s}"/>
                                    </TextBlock>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>

                <!-- Startup Apps Section (Phase F placeholder) -->
                <TextBlock Text="STARTUP APPLICATIONS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,20"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <ItemsControl ItemsSource="{Binding StartupApps}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <DockPanel Margin="0,0,0,6">
                                    <CheckBox DockPanel.Dock="Left" IsChecked="{Binding IsEnabled, Mode=TwoWay}"
                                              VerticalAlignment="Center" Margin="0,0,8,0"
                                              Checked="OnStartupToggled" Unchecked="OnStartupToggled"/>
                                    <StackPanel>
                                        <StackPanel Orientation="Horizontal">
                                            <TextBlock Text="{Binding Name}" Foreground="{DynamicResource GS.Text.Primary}" FontWeight="SemiBold"/>
                                            <Border Background="#FBBF24" CornerRadius="3" Padding="4,1" Margin="6,0,0,0"
                                                    Visibility="{Binding IsRecommendedDisable, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="Safe to disable" FontSize="9" Foreground="#0D1117" FontWeight="Bold"/>
                                            </Border>
                                        </StackPanel>
                                        <TextBlock Text="{Binding Publisher}" FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"/>
                                    </StackPanel>
                                </DockPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
