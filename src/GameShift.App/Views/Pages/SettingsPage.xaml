<Page x:Class="GameShift.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>
    <DockPanel Margin="20">
        <!-- Header with save -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Primary}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource GS.Accent.Primary}" FontSize="12"/>
                <Button Content="Save" Padding="16,6"
                        Background="{DynamicResource GS.Accent.Primary}"
                        Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"
                        IsEnabled="{Binding IsDirty, Mode=OneWay}"
                        Click="OnSaveClicked"/>
            </StackPanel>
        </DockPanel>

        <!-- Scrollable settings -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      helpers:ScrollHelper.FixScrolling="True">
            <StackPanel>
                <!-- Startup Section -->
                <TextBlock Text="STARTUP" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Start with Windows"
                                  IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="Start minimized to tray"
                                  IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"/>
                    </StackPanel>
                </Border>

                <!-- Notifications Section -->
                <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Show desktop notifications"
                                  IsChecked="{Binding ShowNotifications, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Notification Types" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                        <CheckBox Content="Game detected toast"
                                  IsChecked="{Binding ShowGameDetectedToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,8"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="Post-session summary toast"
                                  IsChecked="{Binding ShowSessionSummaryToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,8"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="DPC latency alert toast"
                                  IsChecked="{Binding ShowDpcAlertToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,12"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="Suppress notifications during gaming"
                                  IsChecked="{Binding SuppressNotificationsDuringGaming, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,0"/>
                        <TextBlock Text="When enabled, all non-critical notifications are held until the game exits."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="20,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Logging Section -->
                <TextBlock Text="LOGGING" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Enable logging"
                                  IsChecked="{Binding EnableLogging, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Log Level:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,10,0"/>
                            <ComboBox ItemsSource="{Binding LogLevels}"
                                      SelectedItem="{Binding LogLevel, Mode=TwoWay}"
                                      Width="150"
                                      Background="{DynamicResource GS.Surface.Card}"
                                      Foreground="{DynamicResource GS.Text.Primary}"
                                      BorderBrush="{DynamicResource GS.Surface.Border}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Performance Section -->
                <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Memory Threshold (MB)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="Global default. Per-game overrides in Profile Editor."
                                       FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                            <TextBox Text="{Binding MemoryThresholdMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Timer Resolution (100ns units)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="Default 5000 = 0.5ms. Lower = more precise but higher CPU."
                                       FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                            <TextBox Text="{Binding TimerResolution100ns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Background Mode Section -->
                <TextBlock Text="BACKGROUND MODE" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Enable Background Mode"
                                  IsChecked="{Binding BgEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="Always-on system optimizations that run 24/7, independent of gaming sessions."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="20,0,0,12"
                                   TextWrapping="Wrap"/>

                        <!-- Standby List Cleaner -->
                        <TextBlock Text="Standby List Cleaner" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable standby list cleaner"
                                  IsChecked="{Binding BgStandbyListEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,4"/>
                        <TextBlock Text="{Binding BgStandbyListAutoHint, Mode=OneWay}"
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="20,0,0,8"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,6">
                            <TextBlock Text="Standby threshold (MB):" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,8,0" Width="160"/>
                            <TextBox Text="{Binding BgStandbyListStandbyThresholdMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}" Padding="6,4"
                                     IsEnabled="{Binding BgEnabled}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,6">
                            <TextBlock Text="Free memory minimum (MB):" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,8,0" Width="160"/>
                            <TextBox Text="{Binding BgStandbyListFreeMemoryMinMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}" Padding="6,4"
                                     IsEnabled="{Binding BgEnabled}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,6">
                            <TextBlock Text="Poll interval (ms):" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,8,0" Width="160"/>
                            <TextBox Text="{Binding BgStandbyListPollIntervalMs, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}" Padding="6,4"
                                     IsEnabled="{Binding BgEnabled}"/>
                        </StackPanel>
                        <CheckBox Content="Only purge during active gaming sessions"
                                  IsChecked="{Binding BgStandbyListOnlyDuringGaming, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,4"/>
                        <TextBlock Text="When enabled, standby list is never purged while you are not in a game."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="40,0,0,12" TextWrapping="Wrap"/>

                        <!-- Timer Resolution -->
                        <TextBlock Text="Timer Resolution" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable timer resolution lock"
                                  IsChecked="{Binding BgTimerEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,12">
                            <TextBlock Text="Resolution (100ns):" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding BgTimerResolution100ns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}" Padding="6,4"
                                     IsEnabled="{Binding BgEnabled}"/>
                        </StackPanel>

                        <!-- Power Plan -->
                        <TextBlock Text="Power Plan Manager" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable custom power plan"
                                  IsChecked="{Binding BgPowerPlanEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,6"/>
                        <StackPanel Orientation="Horizontal" Margin="20,0,0,12">
                            <TextBlock Text="Idle timeout (min):" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,8,0"/>
                            <TextBox Text="{Binding BgIdleTimeoutMinutes, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="80" Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}" Padding="6,4"
                                     IsEnabled="{Binding BgEnabled}"/>
                        </StackPanel>

                        <!-- Task Deferral -->
                        <TextBlock Text="Task Deferral" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Defer Windows tasks during gaming"
                                  IsChecked="{Binding BgTaskDeferralEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,4"/>
                        <TextBlock Text="Temporarily disables Windows Update, Defrag, and other scheduled tasks while a game is running."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="40,0,0,12" TextWrapping="Wrap"/>

                        <!-- ProBalance -->
                        <TextBlock Text="ProBalance (CPU Restraint)" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Dynamically restrain high-CPU background processes during gaming"
                                  IsChecked="{Binding BgProBalanceEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,4"/>
                        <TextBlock Text="Monitors background process CPU usage every 2 seconds. Processes exceeding 15% CPU for 3 consecutive samples are demoted to BelowNormal priority. Restored when CPU drops below threshold."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="40,0,0,12" TextWrapping="Wrap"/>

                        <!-- Process Priority -->
                        <TextBlock Text="Process Priority" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,6"/>
                        <CheckBox Content="Enable persistent process priority rules"
                                  IsChecked="{Binding BgProcessPriorityEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  IsEnabled="{Binding BgEnabled}"
                                  Margin="20,0,0,4"/>
                        <TextBlock Text="Automatically sets process priorities for configured applications. Configure rules in profiles."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}"
                                   Margin="40,0,0,0" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- System Tweaks Section -->
                <TextBlock Text="SYSTEM TWEAKS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="One-time registry optimizations that benefit all games. Each tweak detects current state and can be individually toggled."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,12"
                                   TextWrapping="Wrap"/>
                        <Button Content="Apply All Recommended" Padding="12,6"
                                Background="{DynamicResource GS.Accent.Primary}"
                                Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Cursor="Hand"
                                HorizontalAlignment="Left" Margin="0,0,0,12"
                                Click="OnApplyAllTweaksClicked"/>
                    </StackPanel>
                </Border>

                <!-- Individual tweaks rendered from code-behind -->
                <ItemsControl x:Name="TweaksList" Margin="0,0,0,15"/>

                <!-- Game Profiles Section -->
                <TextBlock Text="GAME PROFILES" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,8"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Enable Game Profiles"
                                  IsChecked="{Binding GameProfilesEnabled, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,4"/>
                        <TextBlock Text="Automatically applies per-game optimizations (process priority, CPU affinity, launcher demotion) when a game is detected."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="20,0,0,12"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Individual profiles rendered from code-behind -->
                <ItemsControl x:Name="ProfilesList" Margin="0,0,0,15"/>

                <!-- GPU Section -->
                <TextBlock Text="GPU" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GPU Vendor Override" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="Auto-detects GPU vendor. Override if detection fails."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <ComboBox ItemsSource="{Binding GpuVendorOptions}"
                                  SelectedItem="{Binding GpuVendorOverride, Mode=TwoWay}"
                                  Width="150" HorizontalAlignment="Left"
                                  Background="{DynamicResource GS.Surface.Card}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  BorderBrush="{DynamicResource GS.Surface.Border}"/>
                    </StackPanel>
                </Border>

                <!-- DPC Monitoring Section -->
                <TextBlock Text="DPC MONITORING" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Default DPC Threshold (microseconds)" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="Global default. Per-game overrides in Profile Editor."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <TextBox Text="{Binding DefaultDpcThresholdMicroseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" HorizontalAlignment="Left"
                                 Background="{DynamicResource GS.Surface.Base}"
                                 Foreground="{DynamicResource GS.Text.Primary}"
                                 BorderBrush="{DynamicResource GS.Surface.Border}"
                                 Padding="6,4"/>
                    </StackPanel>
                </Border>

                <!-- Network Section -->
                <TextBlock Text="NETWORK" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Ping Monitor Target" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="IP address or hostname for the network ping monitor. Requires app restart."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <TextBox Text="{Binding PingTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" HorizontalAlignment="Left"
                                 Background="{DynamicResource GS.Surface.Base}"
                                 Foreground="{DynamicResource GS.Text.Primary}"
                                 BorderBrush="{DynamicResource GS.Surface.Border}"
                                 Padding="6,4"/>
                    </StackPanel>
                </Border>

                <!-- Security Section -->
                <TextBlock Text="SECURITY" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="VBS / Memory Integrity (HVCI)" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="{Binding VbsHvciStatus, Mode=OneWay}"
                                   FontSize="13" Margin="0,4,0,8"
                                   Foreground="{DynamicResource GS.Accent.Primary}"/>
                        <Button Content="Re-enable Memory Integrity" Padding="12,6"
                                Background="{DynamicResource GS.Accent.Primary}"
                                Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Cursor="Hand"
                                HorizontalAlignment="Left"
                                Visibility="{Binding ShowReEnableButton, Converter={StaticResource BoolToVisibility}}"
                                Click="OnReEnableVbsClicked"/>
                    </StackPanel>
                </Border>

                <!-- Hotkey Section -->
                <TextBlock Text="HOTKEY" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Global Toggle Hotkey" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBox Text="{Binding GlobalHotkeyBinding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180" HorizontalAlignment="Right"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </DockPanel>
                        <TextBlock Text="Press this key combination anywhere to toggle optimizations on/off. Requires app restart to take effect."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Export / Import Section -->
                <TextBlock Text="EXPORT / IMPORT" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="Export Settings" Click="OnExportClicked" Margin="0,0,12,0"
                                    Padding="16,8" Background="{DynamicResource GS.Surface.Base}"
                                    Foreground="{DynamicResource GS.Text.Primary}"
                                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                    Cursor="Hand"/>
                            <Button Content="Import Settings" Click="OnImportClicked"
                                    Padding="16,8" Background="{DynamicResource GS.Surface.Base}"
                                    Foreground="{DynamicResource GS.Text.Primary}"
                                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                    Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="Export saves all settings and profiles to a .gameshift file. Import restores from a previously exported file."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
