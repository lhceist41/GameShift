<Page x:Class="GameShift.App.Views.Pages.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:helpers="clr-namespace:GameShift.App.Helpers"
      FontFamily="Segoe UI" FontSize="14">
    <Page.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
    </Page.Resources>
    <DockPanel Margin="20">
        <!-- Header with save -->
        <DockPanel DockPanel.Dock="Top" Margin="0,0,0,20">
            <TextBlock Text="Settings" FontSize="22" FontWeight="Bold"
                       Foreground="{DynamicResource GS.Text.Primary}"
                       DockPanel.Dock="Left" VerticalAlignment="Center"/>
            <StackPanel Orientation="Horizontal" DockPanel.Dock="Right"
                        HorizontalAlignment="Right">
                <TextBlock Text="{Binding StatusMessage, Mode=OneWay}"
                           VerticalAlignment="Center" Margin="0,0,10,0"
                           Foreground="{DynamicResource GS.Accent.Primary}" FontSize="12"/>
                <Button Content="Save" Padding="16,6"
                        Background="{DynamicResource GS.Accent.Primary}"
                        Foreground="White" BorderThickness="0"
                        FontWeight="SemiBold" Cursor="Hand"
                        IsEnabled="{Binding IsDirty, Mode=OneWay}"
                        Click="OnSaveClicked"/>
            </StackPanel>
        </DockPanel>

        <!-- Scrollable settings -->
        <ScrollViewer VerticalScrollBarVisibility="Auto"
                      helpers:ScrollHelper.FixScrolling="True">
            <StackPanel>
                <!-- Startup Section -->
                <TextBlock Text="STARTUP" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Start with Windows"
                                  IsChecked="{Binding StartWithWindows, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,10"/>
                        <CheckBox Content="Start minimized to tray"
                                  IsChecked="{Binding StartMinimized, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"/>
                    </StackPanel>
                </Border>

                <!-- Notifications Section -->
                <TextBlock Text="NOTIFICATIONS" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Show desktop notifications"
                                  IsChecked="{Binding ShowNotifications, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,12"/>

                        <TextBlock Text="Notification Types" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                        <CheckBox Content="Game detected toast"
                                  IsChecked="{Binding ShowGameDetectedToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,8"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="Post-session summary toast"
                                  IsChecked="{Binding ShowSessionSummaryToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,8"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="DPC latency alert toast"
                                  IsChecked="{Binding ShowDpcAlertToast, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="20,0,0,12"
                                  IsEnabled="{Binding ShowNotifications}"/>

                        <CheckBox Content="Suppress notifications during gaming"
                                  IsChecked="{Binding SuppressNotificationsDuringGaming, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,0"/>
                        <TextBlock Text="When enabled, all non-critical notifications are held until the game exits."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="20,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Logging Section -->
                <TextBlock Text="LOGGING" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <CheckBox Content="Enable logging"
                                  IsChecked="{Binding EnableLogging, Mode=TwoWay}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Log Level:" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}" Margin="0,0,10,0"/>
                            <ComboBox ItemsSource="{Binding LogLevels}"
                                      SelectedItem="{Binding LogLevel, Mode=TwoWay}"
                                      Width="150"
                                      Background="{DynamicResource GS.Surface.Card}"
                                      Foreground="{DynamicResource GS.Text.Primary}"
                                      BorderBrush="{DynamicResource GS.Surface.Border}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Performance Section -->
                <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,12">
                            <TextBlock Text="Memory Threshold (MB)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="Global default. Per-game overrides in Profile Editor."
                                       FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                            <TextBox Text="{Binding MemoryThresholdMB, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </StackPanel>

                        <StackPanel>
                            <TextBlock Text="Timer Resolution (100ns units)" FontWeight="SemiBold"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBlock Text="Default 5000 = 0.5ms. Lower = more precise but higher CPU."
                                       FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                            <TextBox Text="{Binding TimerResolution100ns, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="100" HorizontalAlignment="Left"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- GPU Section -->
                <TextBlock Text="GPU" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="GPU Vendor Override" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="Auto-detects GPU vendor. Override if detection fails."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <ComboBox ItemsSource="{Binding GpuVendorOptions}"
                                  SelectedItem="{Binding GpuVendorOverride, Mode=TwoWay}"
                                  Width="150" HorizontalAlignment="Left"
                                  Background="{DynamicResource GS.Surface.Card}"
                                  Foreground="{DynamicResource GS.Text.Primary}"
                                  BorderBrush="{DynamicResource GS.Surface.Border}"/>
                    </StackPanel>
                </Border>

                <!-- DPC Monitoring Section -->
                <TextBlock Text="DPC MONITORING" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Default DPC Threshold (microseconds)" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="Global default. Per-game overrides in Profile Editor."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <TextBox Text="{Binding DefaultDpcThresholdMicroseconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="100" HorizontalAlignment="Left"
                                 Background="{DynamicResource GS.Surface.Base}"
                                 Foreground="{DynamicResource GS.Text.Primary}"
                                 BorderBrush="{DynamicResource GS.Surface.Border}"
                                 Padding="6,4"/>
                    </StackPanel>
                </Border>

                <!-- Network Section -->
                <TextBlock Text="NETWORK" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="Ping Monitor Target" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="IP address or hostname for the network ping monitor. Requires app restart."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,2,0,6"/>
                        <TextBox Text="{Binding PingTarget, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                 Width="200" HorizontalAlignment="Left"
                                 Background="{DynamicResource GS.Surface.Base}"
                                 Foreground="{DynamicResource GS.Text.Primary}"
                                 BorderBrush="{DynamicResource GS.Surface.Border}"
                                 Padding="6,4"/>
                    </StackPanel>
                </Border>

                <!-- Security Section -->
                <TextBlock Text="SECURITY" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <TextBlock Text="VBS / Memory Integrity (HVCI)" FontWeight="SemiBold"
                                   Foreground="{DynamicResource GS.Text.Primary}"/>
                        <TextBlock Text="{Binding VbsHvciStatus, Mode=OneWay}"
                                   FontSize="13" Margin="0,4,0,8"
                                   Foreground="{DynamicResource GS.Accent.Primary}"/>
                        <Button Content="Re-enable Memory Integrity" Padding="12,6"
                                Background="{DynamicResource GS.Accent.Primary}"
                                Foreground="White" BorderThickness="0"
                                FontWeight="SemiBold" Cursor="Hand"
                                HorizontalAlignment="Left"
                                Visibility="{Binding ShowReEnableButton, Converter={StaticResource BoolToVisibility}}"
                                Click="OnReEnableVbsClicked"/>
                    </StackPanel>
                </Border>

                <!-- Hotkey Section -->
                <TextBlock Text="HOTKEY" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,8">
                            <TextBlock Text="Global Toggle Hotkey" VerticalAlignment="Center"
                                       Foreground="{DynamicResource GS.Text.Primary}"/>
                            <TextBox Text="{Binding GlobalHotkeyBinding, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                     Width="180" HorizontalAlignment="Right"
                                     Foreground="{DynamicResource GS.Text.Primary}"
                                     Background="{DynamicResource GS.Surface.Base}"
                                     BorderBrush="{DynamicResource GS.Surface.Border}"
                                     Padding="6,4"/>
                        </DockPanel>
                        <TextBlock Text="Press this key combination anywhere to toggle optimizations on/off. Requires app restart to take effect."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Export / Import Section -->
                <TextBlock Text="EXPORT / IMPORT" FontSize="11" FontWeight="Bold"
                           Foreground="{DynamicResource GS.Text.Secondary}" Margin="0,0,0,8"/>

                <Border Background="{DynamicResource GS.Surface.Card}" CornerRadius="8"
                        Padding="15" Margin="0,0,0,15"
                        BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" Margin="0,0,0,8">
                            <Button Content="Export Settings" Click="OnExportClicked" Margin="0,0,12,0"
                                    Padding="16,8" Background="{DynamicResource GS.Surface.Base}"
                                    Foreground="{DynamicResource GS.Text.Primary}"
                                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                    Cursor="Hand"/>
                            <Button Content="Import Settings" Click="OnImportClicked"
                                    Padding="16,8" Background="{DynamicResource GS.Surface.Base}"
                                    Foreground="{DynamicResource GS.Text.Primary}"
                                    BorderBrush="{DynamicResource GS.Surface.Border}" BorderThickness="1"
                                    Cursor="Hand"/>
                        </StackPanel>
                        <TextBlock Text="Export saves all settings and profiles to a .gameshift file. Import restores from a previously exported file."
                                   FontSize="11" Foreground="{DynamicResource GS.Text.Secondary}" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Page>
