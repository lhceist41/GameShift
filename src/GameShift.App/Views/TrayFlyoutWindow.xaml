<Window x:Class="GameShift.App.Views.TrayFlyoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameShift Status"
        Width="320" Height="280"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/GameShiftTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>
    <Border Background="{DynamicResource GS.Surface.Card}"
            BorderBrush="{DynamicResource GS.Surface.Border}"
            BorderThickness="1" CornerRadius="8"
            Margin="4">
        <!-- Margin=4 provides shadow space; actual content is inside -->
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="16">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Header -->
            <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,8">
                <TextBlock Text="GameShift" FontSize="15" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"/>
            </StackPanel>

            <!-- Separator -->
            <Rectangle Grid.Row="1" Height="1" Fill="{DynamicResource GS.Surface.Border}" Margin="0,0,0,12"/>

            <!-- Status Row -->
            <DockPanel Grid.Row="2" Margin="0,0,0,12">
                <TextBlock Text="Status" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0" VerticalAlignment="Center"
                             Fill="{Binding StatusColor}"/>
                    <TextBlock Text="{Binding StatusText}" FontSize="13" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                </StackPanel>
            </DockPanel>

            <!-- DPC Latency Row -->
            <DockPanel Grid.Row="3" Margin="0,0,0,12">
                <TextBlock Text="DPC Latency" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding DpcText}" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"/>
            </DockPanel>

            <!-- Optimizations Row -->
            <DockPanel Grid.Row="4" Margin="0,0,0,12">
                <TextBlock Text="Optimizations" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding OptimizationCount}" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"/>
            </DockPanel>

            <!-- Background Mode Row -->
            <DockPanel Grid.Row="5" Margin="0,0,0,12">
                <TextBlock Text="Background" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding BgModeText}" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"/>
            </DockPanel>

            <!-- Profile Row -->
            <DockPanel Grid.Row="6" Margin="0,0,0,12">
                <TextBlock Text="Profile" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="12" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding ProfileText}" HorizontalAlignment="Right"
                           FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"/>
            </DockPanel>

            <!-- Separator -->
            <Rectangle Grid.Row="7" Height="1" Fill="{DynamicResource GS.Surface.Border}" Margin="0,0,0,12"/>

            <!-- Session Info -->
            <StackPanel Grid.Row="8">
                <TextBlock Text="Active Session" Foreground="{DynamicResource GS.Text.Secondary}"
                           FontSize="11" FontWeight="SemiBold" Margin="0,0,0,4"/>
                <TextBlock Text="{Binding SessionInfo}" FontSize="14" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Text.Primary}"
                           TextTrimming="CharacterEllipsis"/>
            </StackPanel>
        </Grid>
    </Border>
</Window>
