<Window x:Class="GameShift.App.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameShift Update" Width="520" Height="420"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117"
        FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/GameShiftTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>

            <!-- Ghost button style (used by secondary actions) -->
            <Style x:Key="GhostButton" TargetType="Button">
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="Foreground" Value="#8B949E"/>
                <Setter Property="BorderBrush" Value="#30363D"/>
                <Setter Property="BorderThickness" Value="1"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    BorderBrush="{TemplateBinding BorderBrush}"
                                    BorderThickness="{TemplateBinding BorderThickness}"
                                    CornerRadius="6" Padding="14,7">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Foreground" Value="#E6EDF3"/>
                                    <Setter Property="BorderBrush" Value="#8B949E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Primary blue button style -->
            <Style x:Key="PrimaryButton" TargetType="Button">
                <Setter Property="Background" Value="#58A6FF"/>
                <Setter Property="Foreground" Value="#FFFFFF"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="18,7">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#79B8FF"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#388BFD"/>
                                </Trigger>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Background" Value="#21262D"/>
                                    <Setter Property="Foreground" Value="#8B949E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>

            <!-- Green install button style -->
            <Style x:Key="GreenButton" TargetType="Button">
                <Setter Property="Background" Value="#4ADE80"/>
                <Setter Property="Foreground" Value="#0D1117"/>
                <Setter Property="BorderThickness" Value="0"/>
                <Setter Property="FontSize" Value="13"/>
                <Setter Property="FontWeight" Value="SemiBold"/>
                <Setter Property="Cursor" Value="Hand"/>
                <Setter Property="Template">
                    <Setter.Value>
                        <ControlTemplate TargetType="Button">
                            <Border Background="{TemplateBinding Background}"
                                    CornerRadius="6" Padding="18,7">
                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#6EE7A0"/>
                                </Trigger>
                                <Trigger Property="IsPressed" Value="True">
                                    <Setter Property="Background" Value="#22C55E"/>
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Setter.Value>
                </Setter>
            </Style>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="36,28,36,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="Update Available"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#E6EDF3"
                       Margin="0,0,0,8"/>
            <TextBlock x:Name="VersionText"
                       FontSize="14"
                       Foreground="#58A6FF"
                       Margin="0,0,0,4"/>
            <Rectangle Height="1" Fill="#30363D" Margin="0,10,0,0"/>

            <!-- Urgent update banner (shown for critical fixes) -->
            <Border x:Name="UrgentBanner" Visibility="Collapsed"
                    Background="#3B1218" CornerRadius="6" Padding="12,8" Margin="0,10,0,0"
                    BorderBrush="#F85149" BorderThickness="1">
                <TextBlock x:Name="UrgentBannerText"
                           FontSize="12" FontWeight="SemiBold"
                           Foreground="#F85149" TextWrapping="Wrap"/>
            </Border>
        </StackPanel>

        <!-- Row 1: Content area -->
        <Grid Grid.Row="1">
            <!-- Release notes (Initial state) -->
            <StackPanel x:Name="NotesPanel" Visibility="Visible">
                <TextBlock Text="What's new:"
                           FontSize="12" Foreground="#8B949E"
                           Margin="0,0,0,8"/>
                <Border Background="#161B22" CornerRadius="8"
                        BorderBrush="#30363D" BorderThickness="1">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="16,14"
                                  MaxHeight="180">
                        <TextBlock x:Name="ReleaseNotesText"
                                   FontSize="13" LineHeight="20"
                                   Foreground="#C9D1D9"
                                   TextWrapping="Wrap"
                                   Text="Loading release notes..."/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Download progress (Downloading state) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed"
                        VerticalAlignment="Center">
                <TextBlock x:Name="DownloadStatusText"
                           FontSize="14" Foreground="#E6EDF3"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,16"
                           Text="Downloading update..."/>
                <ProgressBar x:Name="DownloadProgress"
                             Height="6"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Background="#21262D"
                             Foreground="#58A6FF"
                             BorderThickness="0"
                             Margin="0,0,0,10"/>
                <TextBlock x:Name="ProgressPercentText"
                           FontSize="12" Foreground="#8B949E"
                           HorizontalAlignment="Center"
                           Text="0%"/>
            </StackPanel>

            <!-- Error state -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText"
                           FontSize="14" Foreground="#F85149"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,16"
                           Text="Download failed. Please try again."/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Button bar -->
        <StackPanel Grid.Row="2" Margin="0,20,0,0">
            <!-- Initial state buttons -->
            <StackPanel x:Name="InitialButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="RemindLaterButton"
                        Content="Remind Me Later"
                        Height="36" Margin="0,0,10,0"
                        Style="{StaticResource GhostButton}"
                        Click="OnRemindLaterClicked"/>

                <Button x:Name="SkipVersionButton"
                        Content="Skip This Version"
                        Height="36" Margin="0,0,10,0"
                        Style="{StaticResource GhostButton}"
                        Click="OnSkipClicked"/>

                <Button x:Name="DownloadButton"
                        Content="Download &amp; Install"
                        Height="36"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnDownloadClicked"/>
            </StackPanel>

            <!-- Downloading state buttons -->
            <StackPanel x:Name="DownloadingButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Height="36"
                        Style="{StaticResource GhostButton}"
                        Click="OnCancelClicked"/>
            </StackPanel>

            <!-- Ready state buttons -->
            <StackPanel x:Name="ReadyButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="LaterButton"
                        Content="Later"
                        Height="36" Margin="0,0,10,0"
                        Style="{StaticResource GhostButton}"
                        Click="OnRemindLaterClicked"/>

                <Button x:Name="InstallButton"
                        Content="Install &amp; Restart"
                        Height="36"
                        Style="{StaticResource GreenButton}"
                        Click="OnInstallClicked"/>
            </StackPanel>

            <!-- Error state buttons -->
            <StackPanel x:Name="ErrorButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="DismissButton"
                        Content="Close"
                        Height="36" Margin="0,0,10,0"
                        Style="{StaticResource GhostButton}"
                        Click="OnRemindLaterClicked"/>

                <Button x:Name="RetryButton"
                        Content="Try Again"
                        Height="36"
                        Style="{StaticResource PrimaryButton}"
                        Click="OnDownloadClicked"/>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
