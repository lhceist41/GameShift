<Window x:Class="GameShift.App.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameShift Update" Width="460" Height="360"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        Background="#0D1117"
        FontFamily="Segoe UI"
        Closing="Window_Closing">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/GameShiftTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Grid Margin="32,24,32,20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Row 0: Header -->
        <StackPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="Update Available"
                       FontSize="22" FontWeight="SemiBold"
                       Foreground="#E6EDF3"
                       Margin="0,0,0,6"/>
            <TextBlock x:Name="VersionText"
                       FontSize="14"
                       Foreground="#58A6FF"
                       Margin="0,0,0,4"/>
            <Rectangle Height="1" Fill="#30363D" Margin="0,8,0,0"/>
        </StackPanel>

        <!-- Row 1: Content area -->
        <Grid Grid.Row="1">
            <!-- Release notes (Initial state) -->
            <StackPanel x:Name="NotesPanel" Visibility="Visible">
                <TextBlock Text="What's new:"
                           FontSize="12" Foreground="#8B949E"
                           Margin="0,0,0,6"/>
                <Border Background="#161B22" CornerRadius="6"
                        BorderBrush="#30363D" BorderThickness="1"
                        MaxHeight="140">
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  Padding="12,10">
                        <TextBlock x:Name="ReleaseNotesText"
                                   FontSize="13"
                                   Foreground="#C9D1D9"
                                   TextWrapping="Wrap"
                                   Text="Loading release notes..."/>
                    </ScrollViewer>
                </Border>
            </StackPanel>

            <!-- Download progress (Downloading state) -->
            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed"
                        VerticalAlignment="Center">
                <TextBlock x:Name="DownloadStatusText"
                           FontSize="14" Foreground="#E6EDF3"
                           HorizontalAlignment="Center"
                           Margin="0,0,0,12"
                           Text="Downloading update..."/>
                <ProgressBar x:Name="DownloadProgress"
                             Height="6"
                             Minimum="0" Maximum="100"
                             Value="0"
                             Background="#21262D"
                             Foreground="#58A6FF"
                             BorderThickness="0"
                             Margin="0,0,0,8"/>
                <TextBlock x:Name="ProgressPercentText"
                           FontSize="12" Foreground="#8B949E"
                           HorizontalAlignment="Center"
                           Text="0%"/>
            </StackPanel>

            <!-- Error state -->
            <StackPanel x:Name="ErrorPanel" Visibility="Collapsed"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="ErrorText"
                           FontSize="14" Foreground="#F85149"
                           TextWrapping="Wrap"
                           TextAlignment="Center"
                           Margin="0,0,0,16"
                           Text="Download failed. Please try again."/>
            </StackPanel>
        </Grid>

        <!-- Row 2: Button bar -->
        <StackPanel Grid.Row="2" Margin="0,16,0,0">
            <!-- Initial state buttons -->
            <StackPanel x:Name="InitialButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right">
                <Button x:Name="RemindLaterButton"
                        Content="Remind Me Later"
                        Width="120" Height="34"
                        Margin="0,0,8,0"
                        Click="OnRemindLaterClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="BorderBrush" Value="#30363D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Setter Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="SkipVersionButton"
                        Content="Skip This Version"
                        Width="130" Height="34"
                        Margin="0,0,8,0"
                        Click="OnSkipClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="BorderBrush" Value="#30363D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Setter Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="DownloadButton"
                        Content="Download &amp; Install"
                        Width="140" Height="34"
                        Click="OnDownloadClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#58A6FF"/>
                            <Setter Property="Foreground" Value="#0D1117"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#79B8FF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#388BFD"/>
                                            </Trigger>
                                            <Trigger Property="IsEnabled" Value="False">
                                                <Setter Property="Background" Value="#21262D"/>
                                                <Setter Property="Foreground" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Downloading state buttons -->
            <StackPanel x:Name="DownloadingButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="CancelButton"
                        Content="Cancel"
                        Width="100" Height="34"
                        Click="OnCancelClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="BorderBrush" Value="#30363D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Setter Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Ready state buttons -->
            <StackPanel x:Name="ReadyButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="LaterButton"
                        Content="Later"
                        Width="80" Height="34"
                        Margin="0,0,8,0"
                        Click="OnRemindLaterClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="BorderBrush" Value="#30363D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Setter Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="InstallButton"
                        Content="Install &amp; Restart"
                        Width="140" Height="34"
                        Click="OnInstallClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#4ADE80"/>
                            <Setter Property="Foreground" Value="#0D1117"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#6EE7A0"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#22C55E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>

            <!-- Error state buttons -->
            <StackPanel x:Name="ErrorButtons" Orientation="Horizontal"
                        HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="DismissButton"
                        Content="Close"
                        Width="80" Height="34"
                        Margin="0,0,8,0"
                        Click="OnRemindLaterClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="Transparent"/>
                            <Setter Property="Foreground" Value="#8B949E"/>
                            <Setter Property="BorderBrush" Value="#30363D"/>
                            <Setter Property="BorderThickness" Value="1"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Foreground" Value="#E6EDF3"/>
                                                <Setter Property="BorderBrush" Value="#8B949E"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>

                <Button x:Name="RetryButton"
                        Content="Try Again"
                        Width="100" Height="34"
                        Click="OnDownloadClicked">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Background" Value="#58A6FF"/>
                            <Setter Property="Foreground" Value="#0D1117"/>
                            <Setter Property="BorderThickness" Value="0"/>
                            <Setter Property="FontSize" Value="13"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Cursor" Value="Hand"/>
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}"
                                                CornerRadius="6" Padding="10,6">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#79B8FF"/>
                                            </Trigger>
                                            <Trigger Property="IsPressed" Value="True">
                                                <Setter Property="Background" Value="#388BFD"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </StackPanel>
    </Grid>
</Window>
