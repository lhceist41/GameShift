<Window x:Class="GameShift.App.Views.ToastNotificationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="GameShift Session Summary"
        Width="320" Height="180"
        WindowStyle="None"
        AllowsTransparency="True"
        ShowInTaskbar="False"
        ShowActivated="False"
        Topmost="True"
        ResizeMode="NoResize"
        Background="Transparent"
        FontFamily="Segoe UI">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="/Themes/GameShiftTheme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Background="{DynamicResource GS.Surface.Card}"
            BorderBrush="{DynamicResource GS.Surface.Border}"
            BorderThickness="1" CornerRadius="8"
            Margin="4">
        <Border.Effect>
            <DropShadowEffect BlurRadius="12" ShadowDepth="2" Opacity="0.4" Color="Black"/>
        </Border.Effect>

        <Grid Margin="16,12">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Title -->
            <DockPanel Grid.Row="0" Margin="0,0,0,4">
                <TextBlock Text="Session Summary" FontSize="13" FontWeight="SemiBold"
                           Foreground="{DynamicResource GS.Accent.Primary}"
                           VerticalAlignment="Center"/>
                <Button x:Name="CloseButton" Content="X" DockPanel.Dock="Right"
                        HorizontalAlignment="Right" VerticalAlignment="Center"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{DynamicResource GS.Text.Secondary}"
                        FontSize="11" Cursor="Hand" Padding="4,2"
                        Click="OnCloseClicked"/>
            </DockPanel>

            <!-- Game Name -->
            <TextBlock x:Name="GameNameText" Grid.Row="1" FontSize="15" FontWeight="SemiBold"
                       Foreground="{DynamicResource GS.Text.Primary}"
                       TextTrimming="CharacterEllipsis" Margin="0,0,0,8"/>

            <!-- Separator -->
            <Rectangle Grid.Row="2" Height="1" Fill="{DynamicResource GS.Surface.Border}" Margin="0,0,0,8"/>

            <!-- Stats Grid: 2 columns x 2 rows -->
            <Grid Grid.Row="3">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Duration -->
                <StackPanel Grid.Row="0" Grid.Column="0" Margin="0,0,8,8">
                    <TextBlock Text="Duration" FontSize="11"
                               Foreground="{DynamicResource GS.Text.Secondary}"/>
                    <TextBlock x:Name="DurationText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                </StackPanel>

                <!-- Optimizations Applied -->
                <StackPanel Grid.Row="0" Grid.Column="1" Margin="8,0,0,8">
                    <TextBlock Text="Opts Applied" FontSize="11"
                               Foreground="{DynamicResource GS.Text.Secondary}"/>
                    <TextBlock x:Name="OptCountText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                </StackPanel>

                <!-- Avg DPC -->
                <StackPanel Grid.Row="1" Grid.Column="0" Margin="0,0,8,0">
                    <TextBlock Text="Avg DPC" FontSize="11"
                               Foreground="{DynamicResource GS.Text.Secondary}"/>
                    <TextBlock x:Name="AvgDpcText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                </StackPanel>

                <!-- Peak DPC -->
                <StackPanel Grid.Row="1" Grid.Column="1" Margin="8,0,0,0">
                    <TextBlock Text="Peak DPC" FontSize="11"
                               Foreground="{DynamicResource GS.Text.Secondary}"/>
                    <TextBlock x:Name="PeakDpcText" FontSize="14" FontWeight="SemiBold"
                               Foreground="{DynamicResource GS.Text.Primary}"/>
                </StackPanel>
            </Grid>
        </Grid>
    </Border>
</Window>
